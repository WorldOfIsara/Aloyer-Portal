---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../data/site';
import type { NavItem } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  nav?: NavItem[];
  headerBrandText?: string;
  headerBrandLogoSrc?: string;
  headerBrandLogoAlt?: string;
  headerBrandLogoFreestanding?: boolean;
  footerTitle?: string;
  footerDescription?: string;
  bodyClass?: string;
}

const {
  title,
  description = siteConfig.description,
  nav = siteConfig.nav,
  headerBrandText,
  headerBrandLogoSrc,
  headerBrandLogoAlt,
  headerBrandLogoFreestanding = false,
  footerTitle,
  footerDescription,
  bodyClass,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | ${siteConfig.titleSuffix}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya:wght@400;500;700&family=Cinzel:wght@500;700&family=Source+Sans+3:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | {siteConfig.titleSuffix}</title>
  </head>
  <body class={bodyClass}>
    <SiteHeader
      nav={nav}
      brandText={headerBrandText}
      brandLogoSrc={headerBrandLogoSrc}
      brandLogoAlt={headerBrandLogoAlt}
      brandLogoFreestanding={headerBrandLogoFreestanding}
    />
    <main>
      <slot />
    </main>
    <SiteFooter title={footerTitle} description={footerDescription} />
  </body>
</html>

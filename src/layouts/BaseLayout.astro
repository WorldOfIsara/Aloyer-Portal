---
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '../components/SiteHeader.astro';
import CookieConsent from '../components/CookieConsent.astro';
import SearchPalette from '../components/SearchPalette.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import PageParallaxBackground from '../components/PageParallaxBackground.astro';
import { siteConfig } from '../data/site';
import type { NavItem } from '../data/site';
import '../styles/fonts.css';
import '../styles/global.css';
import '../styles/performance-overrides.css';

interface Props {
  title: string;
  description?: string;
  nav?: NavItem[];
  headerBrandText?: string;
  headerBrandLogoSrc?: string;
  headerBrandLogoAlt?: string;
  headerBrandLogoFreestanding?: boolean;
  footerTitle?: string;
  footerDescription?: string;
  bodyClass?: string;
}

const {
  title,
  description = siteConfig.description,
  nav = siteConfig.nav,
  headerBrandText,
  headerBrandLogoSrc,
  headerBrandLogoAlt,
  headerBrandLogoFreestanding = false,
  footerTitle,
  footerDescription,
  bodyClass,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isItPage = Astro.url.pathname.startsWith('/it');
const headerBrandHref = isItPage ? `${base}/it/vorrede` : `${base}/ot/willkommen`;
const headerBrandLabel = isItPage ? 'Zur IT-Vorrede' : 'Zur Startseite';
const isOtModern = bodyClass?.includes('ot-modern') ?? false;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | ${siteConfig.titleSuffix}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logos/haubentaucher-wappen-transparent.png?v=2" />
    <link rel="canonical" href={canonical.toString()} />
    <title>{title} | {siteConfig.titleSuffix}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        // Swipe-Übergang testweise für zwei eigenständige Seiten ohne
        // Onepager-Struktur: /ot/packliste (schiebt Hauptseite nach links
        // weg, kommt von rechts) und /ot/kontakt (exakt andersherum -
        // schiebt Hauptseite nach rechts weg, kommt von links). Markiert
        // wird das per data-Attribut auf <html>, bevor der ClientRouter
        // die Transition startet - die eigentliche Animation steckt in
        // global.css (::view-transition-old/new(root), gescoped auf genau
        // diese Attributwerte, damit alle anderen Seitenwechsel unangetastet
        // bleiben).
        //
        // Vorher gab es hier einen Mechanismus, der beim Verlassen der
        // Packliste sanft zum Zielanker scrollte (weil Astro sonst hart
        // hinspringt). Der ist jetzt bewusst raus: der Swipe-Effekt zeigt
        // die Zielstelle direkt an der richtigen Position, ein zusätzliches
        // Scrollen würde sich mit der Schiebe-Animation beißen. Gilt für
        // beide Routen gleichermaßen.
        const SWIPE_ROUTES = {
          '/ot/packliste': { to: 'to-packliste', from: 'from-packliste' },
          '/ot/kontakt': { to: 'to-kontakt', from: 'from-kontakt' },
        };

        document.addEventListener('astro:before-preparation', (event) => {
          const fromPath = event.from?.pathname ?? window.location.pathname;
          const toPath = event.to?.pathname ?? '';
          const toRoute = SWIPE_ROUTES[toPath];
          const fromRoute = SWIPE_ROUTES[fromPath];

          if (toRoute && !fromRoute) {
            document.documentElement.dataset.pageTransition = toRoute.to;
          } else if (fromRoute && !toRoute) {
            document.documentElement.dataset.pageTransition = fromRoute.from;
          } else {
            delete document.documentElement.dataset.pageTransition;
          }
        });

        // Astros swapRootAttributes() übernimmt beim eigentlichen DOM-Swap
        // die <html>-Attribute des NEUEN Dokuments (so behält z. B. lang=""
        // seinen Wert) - unser oben gesetztes data-page-transition würde
        // dabei verloren gehen, weil das frisch geladene Dokument es noch
        // nicht kennt. Deshalb hier vor dem Swap auf das neue Dokument
        // spiegeln, damit es den Swap übersteht und für die
        // ::view-transition-new(root)-Regel in global.css verfügbar bleibt.
        document.addEventListener('astro:before-swap', (event) => {
          const value = document.documentElement.dataset.pageTransition;
          if (value && event.newDocument) {
            event.newDocument.documentElement.dataset.pageTransition = value;
          }

          // Zurück zum Onepager-Anker (von Packliste ODER Kontakt): Astro
          // springt beim Swap selbst zum Hash-Ziel, respektiert dabei aber
          // die globale CSS-Regel "scroll-behavior: smooth" (html in
          // global.css) - dadurch war trotz entferntem Extra-Skript
          // weiterhin ein sichtbares Hochscrollen zu sehen, das sich mit
          // dem Swipe überschneidet. Für dieses eine Dokument kurzzeitig
          // auf "auto" (instant) umschalten, direkt auf dem NEUEN Dokument
          // gesetzt, weil der Hash-Sprung während/kurz nach dem Swap
          // passiert - danach in astro:page-load wieder zurücksetzen,
          // damit normale Anker-Klicks anderswo weiter sanft scrollen.
          if ((value === 'from-packliste' || value === 'from-kontakt') && event.newDocument) {
            event.newDocument.documentElement.style.scrollBehavior = 'auto';
          }
        });

        document.addEventListener('astro:page-load', () => {
          document.documentElement.style.scrollBehavior = '';
        });
      })();
    </script>
  </head>
  <body class={bodyClass}>
    {isOtModern && <PageParallaxBackground />}
    <SiteHeader
      nav={nav}
      brandText={headerBrandText}
      brandLogoSrc={headerBrandLogoSrc}
      brandLogoAlt={headerBrandLogoAlt}
      brandLogoFreestanding={headerBrandLogoFreestanding}
    />
    <script is:inline define:vars={{ headerBrandHref, headerBrandLabel }}>
      (() => {
        // Muss bei jedem Seitenwechsel erneut laufen, nicht nur beim ersten
        // Laden - siehe Kommentar zum selben Muster in SiteHeader.astro
        // (Regler-Skript).
        function applyBrandLink() {
          const brandLink = document.querySelector('.site-header .brand');
          if (!(brandLink instanceof HTMLAnchorElement)) return;

          brandLink.setAttribute('href', headerBrandHref);
          brandLink.setAttribute('aria-label', headerBrandLabel);
        }

        applyBrandLink();
        document.addEventListener('astro:page-load', applyBrandLink);
      })();
    </script>
    <main>
      <slot />
    </main>
    <ScrollReveal />
    <SearchPalette />
    {
      /*
        CookieConsent bewusst nicht mehr gerendert: seit die Google Fonts
        lokal gehostet werden (siehe styles/fonts.css), gibt es keinen
        einwilligungspflichtigen Drittanbieter-Request mehr, den der
        Banner gaten müsste. Komponente bleibt im Code erhalten (falls
        später wieder ein Dienst dazukommt, der Consent braucht), wird
        aber aktuell nicht mehr eingebunden.
      */
    }
    {false && <CookieConsent />}
  </body>
</html>

---
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '../components/SiteHeader.astro';
import CookieConsent from '../components/CookieConsent.astro';
import SearchPalette from '../components/SearchPalette.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import PageParallaxBackground from '../components/PageParallaxBackground.astro';
import { siteConfig } from '../data/site';
import type { NavItem } from '../data/site';
import '../styles/fonts.css';
import '../styles/global.css';
import '../styles/performance-overrides.css';

interface Props {
  title: string;
  description?: string;
  nav?: NavItem[];
  headerBrandText?: string;
  headerBrandLogoSrc?: string;
  headerBrandLogoAlt?: string;
  headerBrandLogoFreestanding?: boolean;
  footerTitle?: string;
  footerDescription?: string;
  bodyClass?: string;
}

const {
  title,
  description = siteConfig.description,
  nav = siteConfig.nav,
  headerBrandText,
  headerBrandLogoSrc,
  headerBrandLogoAlt,
  headerBrandLogoFreestanding = false,
  footerTitle,
  footerDescription,
  bodyClass,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isItPage = Astro.url.pathname.startsWith('/it');
const headerBrandHref = isItPage ? `${base}/it/vorrede` : `${base}/ot/willkommen`;
const headerBrandLabel = isItPage ? 'Zur IT-Vorrede' : 'Zur Startseite';
const isOtModern = bodyClass?.includes('ot-modern') ?? false;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | ${siteConfig.titleSuffix}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logos/haubentaucher-wappen-transparent.png?v=2" />
    <link rel="canonical" href={canonical.toString()} />
    <title>{title} | {siteConfig.titleSuffix}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        // Von /ot/packliste weg soll ein Klick auf einen Anker-Link (z. B.
        // ein Nav-Punkt zu /ot/willkommen#...) nicht hart zum Abschnitt
        // springen, sondern sanft dorthin scrollen - Astros ClientRouter
        // scrollt beim Seitenwechsel selbst instant zum Hash-Ziel, ohne
        // die CSS scroll-behavior:smooth zu respektieren. Deshalb: Hash
        // vor der Navigation merken und aus der Ziel-URL entfernen (damit
        // Astro nicht selbst hart hinspringt), nach dem Seitenwechsel
        // (astro:page-load) dann selbst weich hinscrollen und den Hash
        // per replaceState wieder in die Adressleiste schreiben. Nur auf
        // der Packliste - überall sonst bleibt Anker-Scroll normal.
        const PENDING_KEY = 'aloy-pending-scroll-anchor';

        document.addEventListener(
          'click',
          (event) => {
            if (window.location.pathname !== '/ot/packliste') return;
            if (!(event.target instanceof Element)) return;

            const link = event.target.closest('a[href]');
            if (!(link instanceof HTMLAnchorElement)) return;

            const url = new URL(link.href, window.location.href);
            if (url.hash && url.pathname !== window.location.pathname) {
              sessionStorage.setItem(PENDING_KEY, `${url.pathname}${url.hash}`);
              url.hash = '';
              link.href = url.toString();
            }
          },
          true,
        );

        function resolvePendingScroll() {
          const pending = sessionStorage.getItem(PENDING_KEY);
          if (!pending) return;
          sessionStorage.removeItem(PENDING_KEY);

          const hashIndex = pending.indexOf('#');
          if (hashIndex === -1) return;
          const pathname = pending.slice(0, hashIndex);
          const hash = pending.slice(hashIndex);
          if (pathname !== window.location.pathname) return;

          const target = document.getElementById(hash.slice(1));
          if (!target) return;

          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(history.state, '', pathname + hash);
        }

        document.addEventListener('astro:page-load', resolvePendingScroll);
      })();
    </script>
  </head>
  <body class={bodyClass}>
    {isOtModern && <PageParallaxBackground />}
    <SiteHeader
      nav={nav}
      brandText={headerBrandText}
      brandLogoSrc={headerBrandLogoSrc}
      brandLogoAlt={headerBrandLogoAlt}
      brandLogoFreestanding={headerBrandLogoFreestanding}
    />
    <script is:inline define:vars={{ headerBrandHref, headerBrandLabel }}>
      (() => {
        // Muss bei jedem Seitenwechsel erneut laufen, nicht nur beim ersten
        // Laden - siehe Kommentar zum selben Muster in SiteHeader.astro
        // (Regler-Skript).
        function applyBrandLink() {
          const brandLink = document.querySelector('.site-header .brand');
          if (!(brandLink instanceof HTMLAnchorElement)) return;

          brandLink.setAttribute('href', headerBrandHref);
          brandLink.setAttribute('aria-label', headerBrandLabel);
        }

        applyBrandLink();
        document.addEventListener('astro:page-load', applyBrandLink);
      })();
    </script>
    <main>
      <slot />
    </main>
    <ScrollReveal />
    <SearchPalette />
    {
      /*
        CookieConsent bewusst nicht mehr gerendert: seit die Google Fonts
        lokal gehostet werden (siehe styles/fonts.css), gibt es keinen
        einwilligungspflichtigen Drittanbieter-Request mehr, den der
        Banner gaten müsste. Komponente bleibt im Code erhalten (falls
        später wieder ein Dienst dazukommt, der Consent braucht), wird
        aber aktuell nicht mehr eingebunden.
      */
    }
    {false && <CookieConsent />}
  </body>
</html>

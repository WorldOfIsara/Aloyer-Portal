---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedContent from '../components/RelatedContent.astro';
import { getRelatedLinks } from '../lib/content';

const related = getRelatedLinks(['mitspielen', 'roter-rat', 'goetterwelt', 'downloads']);
---

<BaseLayout title="Kernregeln" description="Die wichtigsten Leitlinien für faires und stimmiges Aloy-Spiel.">
  <Breadcrumbs items={[{ label: 'Start', href: '/' }, { label: 'Kernregeln', href: '/kernregeln' }]} />

  <section class="surface">
    <p class="kicker">Regelwerk MVP</p>
    <h1>Kernregeln für gemeinsames Spiel</h1>
    <p>
      Diese Seite verdichtet das historische Regelmaterial in eine heute spielbare Form. Ziel ist Verständlichkeit, nicht Vollabdruck alter Dokumente.
    </p>
  </section>

  <section class="surface">
    <h2>Leitprinzipien</h2>
    <ol>
      <li><strong>Sicherheit vor Konsequenz:</strong> Outgame-Sicherheit steht immer über Ingame-Härte.</li>
      <li><strong>Spielbarkeit vor Rechthaberei:</strong> Entscheidungen sollen Szenen öffnen, nicht blockieren.</li>
      <li><strong>Konsistenz vor Spontanchaos:</strong> Bestehende Beschlüsse und Chronik gelten als Referenz.</li>
      <li><strong>Transparenz vor Hinterzimmer:</strong> Wichtige Beschlüsse werden dokumentiert.</li>
      <li><strong>Rollenrespekt:</strong> Unterschiedliche Spielstile haben Platz, solange sie anschlussfähig bleiben.</li>
    </ol>
  </section>

  <section class="surface">
    <h2>MVP-Regelmodule</h2>
    <div class="grid">
      <article>
        <h3>Recht und Urteil</h3>
        <p>Orientierung an Miram, Rat und geordneten Verfahren statt Willkür.</p>
      </article>
      <article>
        <h3>Wachdienst und Schutz</h3>
        <p>Klare Eskalationsstufen für Patrouille, Alarm und Nachbereitung.</p>
      </article>
      <article>
        <h3>Konfliktmoderation</h3>
        <p>Bei Streit gilt: kurz klären, Spielfluss sichern, später sauber nachziehen.</p>
      </article>
    </div>
    <p class="muted">Quelle: kuratierte Auszüge aus "Aloy Drive Complete.pdf" (v.a. Gerichtsordnung, Rat, Spielleitfaden).</p>
  </section>

  <RelatedContent items={related} />
</BaseLayout>

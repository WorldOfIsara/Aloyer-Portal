---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DownloadBox from '../../components/DownloadBox.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import { downloadRecords } from '../../data/content';
import { getRelatedLinks, formatMeta } from '../../lib/content';

export function getStaticPaths() {
  return downloadRecords.map((record) => ({
    params: { slug: record.slug },
    props: { record },
  }));
}

const { record } = Astro.props;
const related = getRelatedLinks(record.related);
---

<BaseLayout title={record.title} description={record.summary}>
  <Breadcrumbs
    items={[
      { label: 'Start', href: '/' },
      { label: 'Downloads', href: '/downloads' },
      { label: record.title, href: `/downloads/${record.slug}` },
    ]}
  />

  <section class="surface">
    <p class="kicker">DownloadAsset</p>
    <h1>{record.title}</h1>
    <p>{record.summary}</p>
    <div class="meta-row">
      <span class="pill">{formatMeta(record)}</span>
      {record.tags.map((tag) => <span class="pill">{tag}</span>)}
    </div>
  </section>

  <DownloadBox
    title={record.title}
    filename={record.filename}
    fileType={record.fileType}
    fileSize={record.fileSize}
    note="Die Bereitstellung erfolgt im MVP über kuratierten Release-Prozess. Bitte über den Kontaktweg anfragen, wenn die Datei noch nicht öffentlich verlinkt ist."
  />

  <section class="surface">
    {record.sections.map((section) => (
      <article id={section.id}>
        <h2>{section.heading}</h2>
        {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </article>
    ))}
    <p class="muted">Quellen: {record.source.join(' | ')}</p>
  </section>

  <RelatedContent items={related} />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden" description="Die angeforderte Seite existiert nicht oder wurde verschoben.">
  <section class="surface">
    <p class="kicker">404</p>
    <h1>Diese Seite wurde verschoben</h1>
    <p>Nutze die Navigation oder die Suche, um den neuen Pfad zu finden.</p>
    <div class="meta-row">
      <a href="/portal" class="btn">Zur Startseite</a>
      <a href="/ot" class="btn btn-secondary">Zum OT-Bereich</a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="IT-Bereich" description="In-Time Darstellung im Aloyer Stil.">
  <Breadcrumbs items={[{ label: 'Start', href: '/portal' }, { label: 'IT-Bereich', href: '/it' }]} />

  <section class="surface herald">
    <p class="kicker">Aushang zu Grodaus</p>
    <h1>Höret, Volk der Aloyer Lande</h1>
    <p>
      Im Namen des Rates sei kundgetan: Dieses Schriftwerk dient fortan als öffentlicher Aushang
      für Boten, Gesuche und kundige Nachrichten aus den Landen Aloys.
    </p>
  </section>

  <section class="grid">
    <article class="surface">
      <h2>Bekanntmachung</h2>
      <p>
        Reisende, Söldner, Handwerker und Bürger mögen hier künftig Rat und Wege finden.
        Weitere Schriften werden nach und nach ergänzt.
      </p>
    </article>

    <article class="surface">
      <h2>Derzeit ausgehängt</h2>
      <ul>
        <li>Grundsatz des ehrbaren Umgangs</li>
        <li>Hinweise zu Wache und Geleit</li>
        <li>Erste Kunde aus Rat und Land</li>
      </ul>
    </article>
  </section>

  <section class="surface">
    <p class="muted">
      Dieser Bereich ist bewusst reduziert und wird Schritt für Schritt mit IT-Inhalten ausgebaut.
    </p>
  </section>
</BaseLayout>

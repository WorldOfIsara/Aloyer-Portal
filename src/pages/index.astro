---
const title = 'Aloy - Einstieg';
const description = 'Einstieg in das Aloy Portal.';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <main class="splash">
      <a class="logo-link" href="/portal" aria-label="Zum Portal">
        <img src="/logos/wappen-aloy-full.svg" alt="Aloy Wappen" class="logo" />
      </a>
      <p class="intro">
        Willkommen bei den Aloyer Söldnern.
        <span>Klicke auf das Wappen, um das Portal zu betreten.</span>
      </p>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    font-family: 'Alegreya', 'Georgia', serif;
    color: #1f120b;
    background:
      radial-gradient(1200px 500px at 12% -8%, rgba(187, 98, 53, 0.35), transparent 60%),
      radial-gradient(900px 460px at 85% 8%, rgba(127, 47, 31, 0.24), transparent 62%),
      linear-gradient(180deg, #f2ecdf 0%, #efe3cb 52%, #ebdcc1 100%);
  }

  .splash {
    min-height: 100vh;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 1rem;
    padding: 1.2rem;
    text-align: center;
  }

  .logo-link {
    display: inline-block;
    border-radius: 20px;
    transition: transform 180ms ease;
  }

  .logo-link:hover,
  .logo-link:focus-visible {
    transform: scale(1.02);
  }

  .logo {
    width: min(78vw, 560px);
    max-height: 72vh;
    object-fit: contain;
    filter:
      drop-shadow(0 24px 36px rgba(52, 38, 26, 0.34))
      drop-shadow(0 8px 16px rgba(127, 47, 31, 0.25));
  }

  .intro {
    margin: 0;
    font-size: clamp(1.1rem, 2.4vw, 1.35rem);
    line-height: 1.5;
    font-weight: 600;
  }

  .intro span {
    display: block;
    margin-top: 0.25rem;
    font-weight: 500;
    opacity: 0.92;
  }
</style>

---
const title = 'Willkommen in Aloy';
const description = 'Einstieg in das Aloy Portal.';

// Entfernt den abschließenden Schrägstrich.
// Aus "/Aloyer-Portal/" wird dadurch "/Aloyer-Portal".
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link
      rel="icon"
      type="image/svg+xml"
      href={`${base}/favicon.svg`}
    />

    <link
      rel="icon"
      href={`${base}/favicon.ico`}
    />
  </head>

  <body>
    <div
      class="scene"
      aria-hidden="true"
      style={`--scene-bg: url("${base}/pexels-pixabay-326333_1-1-scaled.jpg")`}
    ></div>

    <div class="vignette" aria-hidden="true"></div>

    <main class="splash">
      <a
        class="logo-link reveal reveal-1"
        href={`${base}/portal`}
        aria-label="Zum Portal"
      >
        <img
          src={`${base}/logos/wappen-aloy-full-clean.png`}
          alt="Aloy Wappen"
          class="logo"
        />
      </a>

      <p class="intro reveal reveal-2">
        Willkommen bei den Aloyer Söldnern
        <span>und am Ohmer Grenztor!</span>
      </p>

      <div class="cta-row reveal reveal-3">
        <a
          class="enter-btn"
          href={`${base}/portal`}
        >
          <span>Aloy betreten</span>

          <svg
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M5 12h14M13 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    font-family: 'Alegreya', 'Georgia', serif;
    color: #1f120b;
    background: #140b07;
    overflow: hidden;
  }

  /* Langsamer Ken-Burns-Zoom auf dem Hintergrund */
  .scene {
    position: fixed;
    inset: -6%;
    z-index: -2;

    background:
      linear-gradient(
        180deg,
        rgba(27, 15, 9, 0.42),
        rgba(27, 15, 9, 0.5)
      ),
      radial-gradient(
        1200px 600px at 50% 45%,
        rgba(250, 238, 210, 0.4),
        transparent 60%
      ),
      var(--scene-bg) center / cover no-repeat;

    transform: scale(1.06);
    animation: kenburns 34s ease-in-out infinite alternate;
  }

  .vignette {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;

    background:
      radial-gradient(
        120% 80% at 50% 42%,
        transparent 52%,
        rgba(12, 8, 6, 0.55) 100%
      );
  }

  .splash {
    min-height: 100vh;
    min-height: 100dvh;

    display: grid;
    place-items: center;
    align-content: center;
    gap: 1.1rem;

    padding: 1.2rem;
    text-align: center;
  }

  .logo-link {
    display: inline-block;
    border-radius: 20px;
    transition: transform 260ms ease;
  }

  .logo-link:hover,
  .logo-link:focus-visible {
    transform: scale(1.03);
  }

  .logo {
    display: block;
    width: min(78vw, 560px);
    max-height: 66vh;
    object-fit: contain;

    filter:
      drop-shadow(0 24px 36px rgba(52, 38, 26, 0.34))
      drop-shadow(0 8px 16px rgba(127, 47, 31, 0.25));
  }

  .intro {
    margin: 0;
    padding: 0.4rem 0;

    color: #fff9ef;

    text-shadow:
      0 2px 12px rgba(0, 0, 0, 0.72),
      0 1px 2px rgba(0, 0, 0, 0.9);

    font-size: clamp(1.1rem, 2.4vw, 1.35rem);
    line-height: 1.5;
    font-weight: 600;
  }

  .intro span {
    display: block;
    margin-top: 0.25rem;
    font-weight: 500;
  }

  .cta-row {
    margin-top: 0.4rem;
  }

  .enter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;

    padding: 0.72rem 1.5rem;
    border: 1px solid rgba(250, 238, 210, 0.35);
    border-radius: 999px;

    font-family: 'Source Sans 3', 'Segoe UI', sans-serif;
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: 0.01em;
    text-decoration: none;

    color: #fff6ea;
    background: linear-gradient(120deg, #7f2f1f, #9f4827);

    box-shadow:
      0 10px 26px rgba(20, 11, 7, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);

    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .enter-btn svg {
    transition: transform 180ms ease;
  }

  .enter-btn:hover,
  .enter-btn:focus-visible {
    transform: translateY(-2px);

    box-shadow:
      0 16px 34px rgba(20, 11, 7, 0.58),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .enter-btn:hover svg,
  .enter-btn:focus-visible svg {
    transform: translateX(4px);
  }

  /* Gestaffeltes Einblenden */
  .reveal {
    opacity: 0;
    transform: translateY(16px);

    animation:
      rise 900ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .reveal-1 {
    animation-delay: 120ms;
  }

  .reveal-2 {
    animation-delay: 480ms;
  }

  .reveal-3 {
    animation-delay: 780ms;
  }

  @keyframes kenburns {
    from {
      transform: scale(1.04) translate3d(0, 0, 0);
    }

    to {
      transform: scale(1.13) translate3d(0, -1.5%, 0);
    }
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scene {
      animation: none;
      transform: scale(1.04);
    }

    .reveal {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

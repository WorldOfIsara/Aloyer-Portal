---
const title = 'Willkommen in Aloy';
const description = 'Einstieg in das Aloy Portal.';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <main class="splash">
      <a class="logo-link" href="/portal" aria-label="Zum Portal">
        <img src="/logos/wappen-aloy-full-clean.png" alt="Aloy Wappen" class="logo" />
      </a>
      <p class="intro">
        Willkommen bei den Aloyer Söldnern
        <span>und am Ohmer Grenztor!</span>
      </p>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    font-family: 'Alegreya', 'Georgia', serif;
    color: #1f120b;
    background:
      linear-gradient(180deg, rgba(27, 15, 9, 0.42), rgba(27, 15, 9, 0.5)),
      radial-gradient(1200px 600px at 50% 45%, rgba(250, 238, 210, 0.4), transparent 60%),
      url('/pexels-pixabay-326333_1-1-scaled.jpg') center / cover no-repeat fixed;
  }

  .splash {
    min-height: 100vh;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 1rem;
    padding: 1.2rem;
    text-align: center;
  }

  .logo-link {
    display: inline-block;
    border-radius: 20px;
    transition: transform 180ms ease;
  }

  .logo-link:hover,
  .logo-link:focus-visible {
    transform: scale(1.02);
  }

  .logo {
    width: min(78vw, 560px);
    max-height: 72vh;
    object-fit: contain;
    filter:
      drop-shadow(0 24px 36px rgba(52, 38, 26, 0.34))
      drop-shadow(0 8px 16px rgba(127, 47, 31, 0.25));
  }

  .intro {
    margin: 0;
    padding: 0.4rem 0;
    color: #fff9ef;
    text-shadow:
      0 2px 12px rgba(0, 0, 0, 0.72),
      0 1px 2px rgba(0, 0, 0, 0.9);
    font-size: clamp(1.1rem, 2.4vw, 1.35rem);
    line-height: 1.5;
    font-weight: 600;
  }

  .intro span {
    display: block;
    margin-top: 0.25rem;
    font-weight: 500;
    opacity: 1;
  }
</style>

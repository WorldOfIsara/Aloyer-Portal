---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import RelatedContent from '../components/RelatedContent.astro';
import { getRelatedLinks } from '../lib/content';

const related = getRelatedLinks(['kernregeln', 'gewandungsleitfaden', 'charakterbogen', 'gwalt']);
---

<BaseLayout title="Mitspielen" description="Einstieg in Aloy in klaren, praktischen Schritten.">
  <Breadcrumbs items={[{ label: 'Start', href: '/' }, { label: 'Mitspielen', href: '/mitspielen' }]} />

  <Hero
    eyebrow="Onboarding"
    title="In 5 Schritten ins Spiel"
    intro="Hier findest du den schnellsten Weg vom ersten Interesse bis zur ersten belastbaren Rolle. Alle Schritte sind auf den MVP abgestimmt und direkt mit Download- und Loreseiten verknüpft."
    primaryCta={{ label: 'Downloads ansehen', href: '/downloads' }}
    secondaryCta={{ label: 'Kernregeln lesen', href: '/kernregeln' }}
  />

  <section class="surface">
    <ol>
      <li>
        <strong>Weltprofil lesen:</strong> Starte mit "Über Aloy" und den Lore-Basisseiten.
      </li>
      <li>
        <strong>Rollenidee wählen:</strong> Entscheide, ob du eher Wache, Zunft, Rat oder Dorfspiel ausprobieren willst.
      </li>
      <li>
        <strong>Gewandung vorbereiten:</strong> Nutze den Leitfaden als visuelle Leitplanke.
      </li>
      <li>
        <strong>Charakterbogen ausfüllen:</strong> Halte Motivation, Beziehungen und Konfliktlinien knapp fest.
      </li>
      <li>
        <strong>Kontakt aufnehmen:</strong> Schicke deine Einstiegsfragen ans Orga-Team.
      </li>
    </ol>
  </section>

  <section class="surface">
    <h2>Rollen mit starkem Einstieg</h2>
    <div class="grid">
      <article>
        <h3>GWALT / Wache</h3>
        <p>Klare Aufgaben, schnelle Szenen, hohe Gruppenkompatibilität.</p>
      </article>
      <article>
        <h3>Zunft und Handel</h3>
        <p>Verhandlungsspiel, Materialkonflikte und politische Anschlussfähigkeit.</p>
      </article>
      <article>
        <h3>Ratsnahes Spiel</h3>
        <p>Diplomatie, Beschlussarbeit und strategische Verantwortung.</p>
      </article>
    </div>
  </section>

  <RelatedContent items={related} />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import { loreRecords } from '../../data/content';
import { getRelatedLinks, formatMeta } from '../../lib/content';

export function getStaticPaths() {
  return loreRecords.map((record) => ({
    params: { slug: record.slug },
    props: { record },
  }));
}

const { record } = Astro.props;
const related = getRelatedLinks(record.related);
---

<BaseLayout title={record.title} description={record.summary}>
  <Breadcrumbs
    items={[
      { label: 'Start', href: '/' },
      { label: 'Welt & Lore', href: '/welt-lore' },
      { label: record.title, href: `/welt-lore/${record.slug}` },
    ]}
  />

  <section class="surface">
    <p class="kicker">{record.contentType}</p>
    <h1>{record.title}</h1>
    <p>{record.summary}</p>
    <div class="meta-row">
      <span class="pill">{formatMeta(record)}</span>
      {record.tags.map((tag) => <span class="pill">{tag}</span>)}
    </div>
  </section>

  <section class="article-layout">
    <div class="surface">
      {record.sections.map((section) => (
        <article id={section.id}>
          <h2>{section.heading}</h2>
          {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          {section.bullets && (
            <ul>
              {section.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}
        </article>
      ))}
      <p class="muted">Quellen: {record.source.join(' | ')}</p>
    </div>
    <TableOfContents entries={record.sections.map((section) => ({ id: section.id, label: section.heading }))} />
  </section>

  <RelatedContent items={related} />
</BaseLayout>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 270px;
    gap: 1rem;
    align-items: start;
  }

  @media (max-width: 930px) {
    .article-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoSlideshow from '../components/PhotoSlideshow.astro';
import {
  portalNav,
  portalBrandText,
  portalBrandAlt,
  portalFooterTitle,
  portalFooterDescription,
} from '../data/portal';

const portalDescription = 'W\u00e4hle zwischen In Time und Off Time.';
---

<BaseLayout
  title="Start"
  description={portalDescription}
  nav={portalNav}
  headerBrandText={portalBrandText}
  headerBrandLogoSrc="/logos/haubentaucher-wappen-transparent.png"
  headerBrandLogoAlt={portalBrandAlt}
  headerBrandLogoFreestanding={true}
  footerTitle={portalFooterTitle}
  footerDescription={portalFooterDescription}
  bodyClass="portal-welcome"
>
  <section class="surface about reveal">
    <h2>Drei zum Gru&szlig;e</h2>
    <p>
      Die Aloyer S&ouml;ldner sind eine LARP-Gruppe mit einer historisch geerdeten Low-Fantasy-Welt, in der soldatische
      Ordnung, republikanische Politik und alltagsnahes Spiel zusammenkommen. Zwischen Grenzdienst, Lagerleben,
      Ratspolitik und pers&ouml;nlichen Geschichten bietet Aloy Raum f&uuml;r Einsteiger ebenso wie f&uuml;r langfristiges
      Charakterspiel.
    </p>
  </section>

  <PhotoSlideshow autoplayMs={4000} />

</BaseLayout>

<style>
  .about {
    text-align: center;
    max-width: 980px;
    margin-inline: auto;
  }

  .about p:last-child {
    max-width: 70ch;
    margin-inline: auto;
  }

  .reveal {
    opacity: 0;
    transform: translateY(14px);
    animation: about-rise 820ms cubic-bezier(0.22, 1, 0.36, 1) 100ms forwards;
  }

  @keyframes about-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackToTop from '../../components/BackToTop.astro';
import WerWirSind from './wir.astro';
import WasWirTun from './tun.astro';
import Hintergrund from './hintergrund.astro';
import Gewandung from './gewandung.astro';
import Regelwerk from './regelwerk.astro';
import Aktuelles from './aktuelles.astro';
import PartnerBlock from './partner-block.astro';
import KontaktBlock from './kontakt-block.astro';
import { getFotostreckeFiles } from '../../lib/fotostrecke';
import {
  portalNav,
  portalBrandText,
  portalBrandAlt,
  portalFooterTitle,
  portalFooterDescription,
} from '../../data/portal';

const portalDescription =
  'Die Aloyer Söldner: wer wir sind, was wir tun, unser Hintergrund, Gewandung und Regelwerk auf einer Seite.';

// Alle Bilder aus user_files/Fotostrecke für die Hero-Slideshow.
const heroSlides = getFotostreckeFiles().map((file, index) => `/fotostrecke/${index}.webp`);
---

<BaseLayout
  title="Start"
  description={portalDescription}
  nav={portalNav}
  headerBrandText={portalBrandText}
  headerBrandLogoSrc="/logos/haubentaucher-wappen-transparent.png"
  headerBrandLogoAlt={portalBrandAlt}
  headerBrandLogoFreestanding={true}
  footerTitle={portalFooterTitle}
  footerDescription={portalFooterDescription}
  bodyClass="portal-welcome ot-modern"
>
  <section class="parallax-hero" data-hero aria-label="Willkommen bei den Aloyer Söldnern">
    <div class="hero-slideshow" aria-hidden="true">
      {
        heroSlides.map((src, index) => (
          <img
            class:list={['hero-slideshow__img', { 'is-active': index === 0 }]}
            src={src}
            alt=""
            loading={index === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        ))
      }
      <div class="hero-slideshow__wash"></div>
    </div>

    {
      heroSlides.length > 1 && (
        <div class="hero-slideshow-dots" data-hero-dots role="tablist" aria-label="Bild ausw&auml;hlen">
          <div class="hero-slideshow-dots__track" data-hero-dots-track>
            {heroSlides.map((_, index) => (
              <button
                type="button"
                class:list={['hero-slideshow-dot', { 'is-active': index === 0 }]}
                data-hero-dot
                data-index={index}
                role="tab"
                aria-label={`Bild ${index + 1} von ${heroSlides.length}`}
                aria-selected={index === 0 ? 'true' : 'false'}
              />
            ))}
          </div>
        </div>
      )
    }

    <div class="hero-wappen" data-hero-wappen aria-hidden="true">
      <img src="/logos/haubentaucher-wappen-transparent.png" alt="" loading="eager" decoding="async" />
    </div>

    <div class="hero-text" data-hero-text>
      <p class="hero-kicker">Aloyer Söldner</p>
      <h1>Drei zum Gru&szlig;e</h1>
      <p class="hero-text-body">
        Die Aloyer S&ouml;ldner sind eine LARP-Gruppe mit einer historisch geerdeten Low-Fantasy-Welt, in der
        soldatische Ordnung, republikanische Politik und alltagsnahes Spiel zusammenkommen. Zwischen Grenzdienst,
        Lagerleben, Ratspolitik und pers&ouml;nlichen Geschichten bietet Aloy Raum f&uuml;r Einsteiger ebenso wie
        f&uuml;r langfristiges Charakterspiel.
      </p>
    </div>
  </section>

  <script>
    function initHero(hero: HTMLElement) {
      if (hero.dataset.heroInitialized === 'true') return;
      hero.dataset.heroInitialized = 'true';

      // Bildwechsel der Hero-Slideshow (einfache Crossfade-Rotation) plus
      // Punkt-Anzeige darunter im Stil von Swipers "dynamic bullets"
      // (https://swiperjs.com/demos/040-pagination-dynamic/core): der
      // aktive Punkt bleibt volle Größe, Nachbarn schrumpfen stufenweise,
      // weiter entfernte Punkte werden unsichtbar, und die Punktreihe
      // schiebt sich mit, sodass der aktive Punkt möglichst mittig bleibt.
      // Nur die Bewegungsmechanik ist von der Demo übernommen - Farben/
      // Formen bleiben im eigenen Pergament-Look, kein Swiper-Blau.
      // Auf Mobile wird die Slideshow nicht angezeigt (siehe CSS,
      // display:none) - dann auch keine Rotation/Timer im Hintergrund
      // laufen lassen, das kostet nur unnötig Akku/CPU.
      const isMobileHero = window.matchMedia('(max-width: 700px)').matches;
      const slides = Array.from(hero.querySelectorAll<HTMLImageElement>('.hero-slideshow__img'));
      const dots = Array.from(hero.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
      const dotsTrack = hero.querySelector<HTMLElement>('[data-hero-dots-track]');

      if (!isMobileHero && slides.length > 1) {
        const DOT_STEP_REM = 1.15; // Breite + Abstand eines Punkts, siehe CSS
        const VISIBLE_DOTS = 5;
        const half = Math.floor(VISIBLE_DOTS / 2);

        let activeIndex = 0;
        let intervalId: number | undefined;

        const updateDots = () => {
          dots.forEach((dot, index) => {
            const distance = Math.abs(index - activeIndex);
            const scale = distance === 0 ? 1 : distance === 1 ? 0.7 : distance === 2 ? 0.4 : 0;

            dot.style.transform = `scale(${scale})`;
            dot.classList.toggle('is-active', index === activeIndex);
            dot.setAttribute('aria-selected', index === activeIndex ? 'true' : 'false');
          });

          if (dotsTrack) {
            const maxOffset = Math.max(0, slides.length - VISIBLE_DOTS);
            const offset = Math.min(Math.max(activeIndex - half, 0), maxOffset);
            dotsTrack.style.transform = `translateX(${-offset * DOT_STEP_REM}rem)`;
          }
        };

        const showSlide = (index: number) => {
          slides[activeIndex].classList.remove('is-active');
          activeIndex = ((index % slides.length) + slides.length) % slides.length;
          slides[activeIndex].classList.add('is-active');
          updateDots();
        };

        const restartAutoplay = () => {
          if (intervalId !== undefined) window.clearInterval(intervalId);
          intervalId = window.setInterval(() => showSlide(activeIndex + 1), 4200);
        };

        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            showSlide(index);
            restartAutoplay();
          });
        });

        updateDots();
        restartAutoplay();
      }

      // Scroll-Fortschritt (0 = oben, 1 = Hero komplett durchgescrollt):
      // steuert per CSS-Variable, wie weit der Willkommenstext ins
      // linke obere Eck wandert und wie weit das Wappen herausfliegt.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function updateHeroProgress() {
        const heroHeight = hero.offsetHeight || 1;
        const progress = Math.min(1, Math.max(0, -hero.getBoundingClientRect().top / heroHeight));
        hero.style.setProperty('--hero-progress', String(progress));
      }

      if (reduceMotion) {
        hero.style.setProperty('--hero-progress', '0');
        return;
      }

      let ticking = false;
      function scheduleUpdate() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(() => {
          updateHeroProgress();
          ticking = false;
        });
      }

      updateHeroProgress();
      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate);
    }

    function initAllHeroes() {
      document.querySelectorAll<HTMLElement>('[data-hero]').forEach(initHero);
    }

    initAllHeroes();
    document.addEventListener('astro:page-load', initAllHeroes);
  </script>

  <WerWirSind />
  <WasWirTun />
  <Hintergrund />
  <Gewandung />
  <Regelwerk />
  <Aktuelles />
  <PartnerBlock />
  <KontaktBlock />

  <BackToTop />
</BaseLayout>

<style>
  .parallax-hero {
    --hero-progress: 0;
    position: relative;
    min-height: 88vh;
    overflow: hidden;
    border-radius: 24px;
    isolation: isolate;
  }

  /* Slideshow als Hero-Hintergrund: 3-4 Bilder, die sich per Crossfade
     abwechseln (siehe Script), plus ein dunkler Wash für Lesbarkeit. */
  .hero-slideshow {
    position: absolute;
    inset: 0;
  }

  .hero-slideshow__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.1s ease;
  }

  .hero-slideshow__img.is-active {
    opacity: 1;
  }

  .hero-slideshow__wash {
    position: absolute;
    inset: 0;
    background: linear-gradient(200deg, rgba(18, 11, 8, 0.32) 0%, rgba(18, 11, 8, 0.68) 65%, rgba(18, 11, 8, 0.82) 100%);
  }

  /*
    Nachgebaut nach Swipers "dynamic bullets"
    (swiperjs.com/demos/040-pagination-dynamic/core): ein Sichtfenster
    (.hero-slideshow-dots, feste Breite, overflow hidden) zeigt maximal
    5 Punkte; die Punktreihe selbst (__track) ist breiter als nötig und
    wird per JS so verschoben, dass der aktive Punkt im Fenster bleibt.
    Größe der Punkte wird ebenfalls per JS (inline transform: scale)
    gesetzt - Nachbarn schrumpfen stufenweise, weiter entfernte werden
    unsichtbar. Farben/Form bleiben im eigenen Look, kein Swiper-Blau.
  */
  .hero-slideshow-dots {
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    z-index: 2;
    overflow: hidden;
    width: calc(5 * 1.15rem);
    transform: translateX(-50%);
  }

  .hero-slideshow-dots__track {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    transition: transform 220ms ease;
  }

  .hero-slideshow-dot {
    flex: 0 0 auto;
    width: 0.6rem;
    height: 0.6rem;
    padding: 0;
    border: 1px solid rgba(248, 236, 210, 0.6);
    border-radius: 999px;
    background: rgba(248, 236, 210, 0.5);
    cursor: pointer;
    transition: background-color 160ms ease, transform 220ms ease, border-color 160ms ease;
  }

  .hero-slideshow-dot:hover,
  .hero-slideshow-dot:focus-visible {
    background: rgba(248, 236, 210, 0.75);
    outline: none;
  }

  .hero-slideshow-dot:focus-visible {
    box-shadow: 0 0 0 3px rgba(248, 236, 210, 0.4);
  }

  .hero-slideshow-dot.is-active {
    background: rgba(248, 236, 210, 0.98);
    border-color: rgba(248, 236, 210, 0.98);
  }

  /*
    Wappen: startet dezent rechts im Bild und fliegt beim Scrollen nach
    rechts oben aus dem sichtbaren Bereich, statt einfach dazustehen.
  */
  .hero-wappen {
    position: absolute;
    top: 50%;
    right: 4%;
    width: min(30vw, 320px);
    opacity: calc(0.5 - var(--hero-progress) * 0.5);
    transform: translateY(-50%) translate(calc(var(--hero-progress) * 55vw), calc(var(--hero-progress) * -45vh))
      rotate(calc(var(--hero-progress) * 35deg));
    transition: opacity 80ms linear;
    will-change: transform, opacity;
  }

  .hero-wappen img {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.4));
  }

  /*
    Text: startet zentriert in der Mitte des Hero, wandert beim
    Scrollen ins linke obere Eck und wird dabei etwas kleiner/kompakter.
  */
  .hero-text {
    position: absolute;
    top: 50%;
    left: 50%;
    max-width: min(60ch, 80vw);
    padding: 1.5rem;
    text-align: center;
    color: #f8ecd2;
    transform: translate(-50%, -50%) translate(calc(var(--hero-progress) * -32vw), calc(var(--hero-progress) * -30vh))
      scale(calc(1 - var(--hero-progress) * 0.28));
    transform-origin: center;
    will-change: transform;
  }

  .hero-kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(230, 155, 107, 0.95);
  }

  .hero-text h1 {
    margin: 0;
    color: #f8ecd2;
  }

  .hero-text-body {
    margin: 1rem 0 0;
    color: rgba(248, 236, 210, 0.92);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-wappen {
      transform: translateY(-50%) !important;
    }

    .hero-text {
      transform: translate(-50%, -50%) !important;
    }

    .hero-slideshow__img {
      transition: none;
    }
  }

  @media (max-width: 700px) {
    .parallax-hero {
      min-height: 64vh;
    }

    /*
      Kein Crossfade-Bilder-Slider auf Mobile (spart Ladezeit/Akku,
      siehe auch der abgeschaltete Timer im Script) - einfach schwarzer
      Hintergrund, konsistent mit dem restlichen Mobile-Look.
    */
    .hero-slideshow__img,
    .hero-slideshow-dots {
      display: none;
    }

    .hero-slideshow__wash {
      background: #000;
    }

    /* Wappen fliegt beim Scrollen ohnehin nur für den Desktop-Effekt raus
       - auf Mobile bringt es nichts, kostet nur Platz. Ganz weg damit. */
    .hero-wappen {
      display: none;
    }

    /*
      Der scroll-gekoppelte Verkleinern/Verschieben-Effekt (--hero-progress,
      siehe Script + .hero-text transform oben) skaliert auf Mobile nicht
      sauber: der Hero ist hier nur 64vh hoch, das Scroll-Fenster dadurch
      sehr kurz, wodurch Text schnell stark verkleinert und verschoben wird
      und dabei "gequetscht"/kaum lesbar wirkt.

      Zusätzlich: die bisherige absolute Positionierung (top:50% relativ
      zur eigenen vh-Höhe) konnte den Text auf manchen Mobilgeräten hinter
      den fixierten Header rutschen lassen, wenn die tatsächliche
      Header-Höhe (zwei Zeilen bei schmalen Screens, Safe-Area-Insets)
      von der Fallback-Annahme abwich. Deshalb hier komplett auf normale
      Flex-Zentrierung umgestellt statt absoluter Prozent-Positionierung -
      der Text liegt dann garantiert innerhalb der (bereits korrekt unter
      dem Header liegenden) Hero-Box, unabhängig von vh-Berechnungen.
    */
    .parallax-hero {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-text {
      position: relative;
      top: auto;
      left: auto;
      transform: none !important;
      max-width: 90vw;
      padding: 1rem;
    }
  }

</style>

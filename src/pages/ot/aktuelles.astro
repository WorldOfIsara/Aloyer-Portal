---
// Onepager-Baustein "Aktuelles". Wird von willkommen.astro als Komponente
// eingebunden (<Aktuelles />). Anders als die reinen Text-Bausteine
// (wir.astro, tun.astro, ...) besteht dieser aus zwei Teilen: der
// Einleitung als <section class="surface onepager-block"> und den
// Terminen aus UpcomingEvents.astro (liest src/data/events.ts) als
// eigenem Element - Terminkarten passen nicht in die Fließtext-Optik
// von .onepager-block, deshalb bleibt UpcomingEvents ein Geschwister-
// Element statt hineingeschachtelt zu werden.
import UpcomingEvents from '../../components/UpcomingEvents.astro';
---

<section id="aktuelles" class="surface onepager-block" data-reveal data-reveal-repeat>
  <h2>Wo die Söldner als nächstes sind</h2>
</section>

<UpcomingEvents />
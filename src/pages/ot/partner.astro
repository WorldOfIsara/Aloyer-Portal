---
// Übersichtsseite mit Links zu Partner- und Freundesgruppen. Die Karten
// selbst stecken in PartnerGrid.astro (gemeinsam genutzt mit dem
// Onepager-Block in willkommen.astro), Inhalte kommen aus
// src/data/partners.ts (zwei getrennte Listen).
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PartnerGrid from '../../components/PartnerGrid.astro';
import { partnerGroups, friendGroups } from '../../data/partners';
---

<BaseLayout title="Freundesgruppen" description="Partner- und befreundete LARP-Gruppen, mit denen die Aloyer Söldner verbunden sind.">
  <Breadcrumbs items={[{ label: 'Start', href: '/' }, { label: 'Freundesgruppen', href: '/ot/partner' }]} />

  <section class="surface">
    <p class="kicker">Partner- &amp; Freundesgruppen</p>
    <h1>Wer noch mit uns unterwegs ist</h1>
    <p>
      Aloy steht nicht allein in den Splitterlanden. Hier findest du Gruppen, mit denen wir befreundet sind oder
      regelmäßig zusammenspielen.
    </p>

    <h2>Partnergruppen</h2>
    {
      partnerGroups.length > 0 ? (
        <PartnerGrid groups={partnerGroups} />
      ) : (
        <p class="partner-empty">Noch keine Partnergruppen eingetragen.</p>
      )
    }

    <h2>Freundesgruppen</h2>
    {
      friendGroups.length > 0 ? (
        <PartnerGrid groups={friendGroups} />
      ) : (
        <p class="partner-empty">Noch keine Freundesgruppen eingetragen.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .partner-empty {
    color: var(--ink-2);
    font-style: italic;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PackingChecklist from '../../components/PackingChecklist.astro';
import {
  portalNav,
  portalBrandText,
  portalBrandAlt,
  portalFooterTitle,
  portalFooterDescription,
} from '../../data/portal';

const pageDescription = 'Interaktive Packliste für Veranstaltungen der Aloyer Söldner.';
---

<BaseLayout
  title="Packliste"
  description={pageDescription}
  nav={portalNav}
  headerBrandText={portalBrandText}
  headerBrandLogoSrc="/logos/haubentaucher-wappen-transparent.png"
  headerBrandLogoAlt={portalBrandAlt}
  headerBrandLogoFreestanding={true}
  footerTitle={portalFooterTitle}
  footerDescription={portalFooterDescription}
  bodyClass="portal-welcome ot-modern"
>
  <section class="surface packing-intro">
    <h1>Packliste</h1>
    <p>
      Eine allgemeine Grundausstattung für Veranstaltungen der Aloyer Söldner. Häkchen werden im Browser
      gespeichert, sodass die Liste beim nächsten Besuch dort weitermacht, wo du aufgehört hast.
    </p>
  </section>

  <PackingChecklist />
</BaseLayout>

<style>
  .packing-intro {
    text-align: center;
    max-width: 980px;
    margin-inline: auto;
  }

  .packing-intro p {
    max-width: 72ch;
    margin-inline: auto;
  }
</style>

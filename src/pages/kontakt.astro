---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="Kontakt" description="Kontakt zur Reulos-Orga für Einstieg, Rollenabstimmung und Dokumente.">
  <Breadcrumbs items={[{ label: 'Start', href: '/' }, { label: 'Kontakt', href: '/kontakt' }]} />

  <section class="surface">
    <p class="kicker">Kontakt</p>
    <h1>Kontakt & Onboarding</h1>
    <p>
      Du möchtest neu einsteigen oder brauchst Material für deinen Charakter? Melde dich mit einem kurzen Steckbrief (Rollenidee, Erfahrung, offene Fragen).
    </p>
  </section>

  <section class="grid">
    <article class="surface">
      <h2>Erstkontakt</h2>
      <p class="muted">Mail</p>
      <p><a href="mailto:orga@reulos-orga.de">orga@reulos-orga.de</a></p>
      <p class="muted">Antwortziel: innerhalb von 3-5 Werktagen.</p>
    </article>

    <article class="surface">
      <h2>Was wir brauchen</h2>
      <ul>
        <li>Kurze Rollenidee und bevorzugter Spielschwerpunkt</li>
        <li>Ob du NSC, GSC oder festen Charakter spielen willst</li>
        <li>Ob du schon Gewandung / Ausrüstung hast</li>
      </ul>
    </article>
  </section>
</BaseLayout>

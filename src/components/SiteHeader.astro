---
import type { NavItem } from '../data/site';

interface Props {
  nav: NavItem[];
  brandText?: string;
  brandLogoSrc?: string;
  brandLogoAlt?: string;
  brandLogoFreestanding?: boolean;
}

const {
  nav,
  brandText = 'Aloy Portal',
  brandLogoSrc = '/logos/haubentaucher-wappen.jpg',
  brandLogoAlt = 'Haubentaucher Logo',
  brandLogoFreestanding = false,
} = Astro.props;
const pathname = Astro.url.pathname;
const isDenseNav = nav.length >= 9;
const isIt = pathname.startsWith('/it');
---

<header class:list={['site-header', { 'is-dense-nav': isDenseNav, 'mode-it': isIt, 'mode-ot': !isIt }]}>
  <div class:list={['wrap', { 'is-dense-nav': isDenseNav }]}>
    <a class="brand" href="/portal" aria-label="Zur Startseite">
      <img
        class:list={['brand-mark', { 'is-freestanding': brandLogoFreestanding }]}
        src={brandLogoSrc}
        alt={brandLogoAlt}
        loading="eager"
        decoding="async"
      />
      <span class="brand-text">{brandText}</span>
    </a>
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-navigation"
      aria-label="Navigation öffnen"
    >
      <span class="nav-toggle-icon" aria-hidden="true"></span>
      <span class="nav-toggle-label">Menü</span>
    </button>
    <nav id="site-navigation" class:list={{ 'is-dense-nav': isDenseNav }} aria-label="Hauptnavigation">
      <ul class:list={{ 'is-dense-nav': isDenseNav }}>
        {
          nav.map((item, index) => {
            const current = pathname === item.href;
            const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
            const hasChildren = Array.isArray(item.children) && item.children.length > 0;
            const hasActiveChild =
              hasChildren &&
              item.children!.some(
                (child) => pathname === child.href || (child.href !== '/' && pathname.startsWith(child.href)),
              );
            const submenuId = `site-submenu-${index}`;
            return (
              <li
                class:list={{
                  'has-children': hasChildren,
                  'has-active-child': hasActiveChild,
                  'is-submenu-open': hasActiveChild,
                }}
              >
                <div class="nav-item-row">
                  <a href={item.href} aria-current={current ? 'page' : undefined} class={active ? 'active' : ''}>
                    {item.label}
                  </a>
                  {
                    hasChildren ? (
                      <button
                        class="submenu-toggle"
                        type="button"
                        aria-expanded={hasActiveChild ? 'true' : 'false'}
                        aria-controls={submenuId}
                        aria-label={`Untermenü ${item.label} ${hasActiveChild ? 'schließen' : 'öffnen'}`}
                      >
                        <span aria-hidden="true"></span>
                      </button>
                    ) : null
                  }
                </div>
                {
                  hasChildren ? (
                    <ul id={submenuId} class="submenu" aria-label={`${item.label} Unterpunkte`}>
                      <li class="submenu-overview">
                        <a href={item.href}>Übersicht: {item.label}</a>
                      </li>
                      {item.children!.map((child) => {
                        const childCurrent = pathname === child.href;
                        const childActive =
                          pathname === child.href || (child.href !== '/' && pathname.startsWith(child.href));
                        return (
                          <li>
                            <a
                              href={child.href}
                              aria-current={childCurrent ? 'page' : undefined}
                              class={childActive ? 'active' : ''}
                            >
                              {child.label}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  ) : null
                }
              </li>
            );
          })
        }
      </ul>
    </nav>
    <div class="header-actions">
      <button
        type="button"
        class="header-search-trigger"
        data-search-trigger
        aria-label="Suche öffnen"
        title="Suche (⌘K)"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
          <path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
        <span class="header-search-kbd" aria-hidden="true">⌘K</span>
      </button>
      <div class="header-mode-switch" role="group" aria-label="Bereich wählen">
        <span class="mode-label" data-mode="it">IT</span>
        <label class="switch" for="headerModeSwitch">
          <input
            id="headerModeSwitch"
            type="checkbox"
            checked={!isIt}
            aria-label="Zwischen IT- und OT-Bereich wechseln"
          />
          <span class="slider" aria-hidden="true"></span>
        </label>
        <span class="mode-label" data-mode="ot">OT</span>
      </div>
    </div>
  </div>
  <script is:inline>
    (() => {
      const modeSwitch = document.getElementById('headerModeSwitch');
      if (!(modeSwitch instanceof HTMLInputElement)) return;
      modeSwitch.addEventListener('change', () => {
        window.location.href = modeSwitch.checked ? '/ot/willkommen' : '/it/vorrede';
      });
    })();
  </script>
  <script is:inline>
    (() => {
      const header = document.currentScript?.closest('.site-header');
      if (!(header instanceof HTMLElement)) return;

      const syncHeaderHeight = () => {
        const height = Math.ceil(header.getBoundingClientRect().height);
        document.documentElement.style.setProperty('--site-header-height', `${height}px`);
      };

      syncHeaderHeight();
      window.requestAnimationFrame(syncHeaderHeight);
      window.addEventListener('resize', syncHeaderHeight);
      document.fonts?.ready.then(syncHeaderHeight);

      if (typeof ResizeObserver === 'function') {
        const headerResizeObserver = new ResizeObserver(syncHeaderHeight);
        headerResizeObserver.observe(header);
      }

      const menuButton = header.querySelector('.nav-toggle');
      const navigation = header.querySelector('#site-navigation');
      const mobileQuery = window.matchMedia('(max-width: 980px)');

      if (!(menuButton instanceof HTMLButtonElement) || !(navigation instanceof HTMLElement)) return;

      const setSubmenuState = (button, open) => {
        const listItem = button.closest('.has-children');
        if (!(button instanceof HTMLButtonElement) || !(listItem instanceof HTMLElement)) return;

        listItem.classList.toggle('is-submenu-open', open);
        button.setAttribute('aria-expanded', String(open));
        const sectionName = button.getAttribute('aria-label')?.replace(/ (öffnen|schließen)$/, '') ?? 'Untermenü';
        button.setAttribute('aria-label', `${sectionName} ${open ? 'schließen' : 'öffnen'}`);
      };

      const toggleSubmenu = (button) => {
        const listItem = button.closest('.has-children');
        if (!(button instanceof HTMLButtonElement) || !(listItem instanceof HTMLElement)) return;

        const willOpen = !listItem.classList.contains('is-submenu-open');

        if (willOpen) {
          header.querySelectorAll('.submenu-toggle').forEach((otherButton) => {
            if (otherButton !== button) setSubmenuState(otherButton, false);
          });
        }

        setSubmenuState(button, willOpen);

        if (willOpen) {
          window.requestAnimationFrame(() => {
            listItem.querySelector('.nav-item-row')?.scrollIntoView({ block: 'nearest' });
          });
        }
      };

      const closeNavigation = (returnFocus = false) => {
        header.classList.remove('nav-open');
        document.body.classList.remove('mobile-nav-open');
        menuButton.setAttribute('aria-expanded', 'false');
        menuButton.setAttribute('aria-label', 'Navigation öffnen');

        header.querySelectorAll('.submenu-toggle').forEach((button) => {
          setSubmenuState(button, false);
        });

        if (returnFocus) menuButton.focus();
      };

      menuButton.addEventListener('click', () => {
        const willOpen = !header.classList.contains('nav-open');
        if (!willOpen) {
          closeNavigation();
          return;
        }

        header.classList.add('nav-open');
        document.body.classList.add('mobile-nav-open');
        menuButton.setAttribute('aria-expanded', 'true');
        menuButton.setAttribute('aria-label', 'Navigation schließen');
      });

      header.querySelectorAll('.submenu-toggle').forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;

        button.addEventListener('click', () => toggleSubmenu(button));

        const listItem = button.closest('.has-children');
        const row = listItem?.querySelector('.nav-item-row');
        const parentLink = row?.querySelector('a');
        parentLink?.addEventListener('click', (event) => {
          if (!mobileQuery.matches) return;
          event.preventDefault();
          toggleSubmenu(button);
        });
      });

      navigation.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          const isMobileAccordionTrigger = link.parentElement?.classList.contains('nav-item-row');
          if (mobileQuery.matches && !isMobileAccordionTrigger) closeNavigation();
        });
      });

      document.addEventListener('click', (event) => {
        if (mobileQuery.matches && header.classList.contains('nav-open') && !header.contains(event.target)) {
          closeNavigation();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && header.classList.contains('nav-open')) {
          closeNavigation(true);
        }
      });

      if (typeof mobileQuery.addEventListener === 'function') {
        mobileQuery.addEventListener('change', () => closeNavigation());
      } else {
        mobileQuery.onchange = () => closeNavigation();
      }
    })();
  </script>
</header>

<style>
  .site-header {
    --header-ink: var(--ink-1);
    --header-panel: rgba(246, 238, 224, 0.98);
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(246, 238, 224, 0.9);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(177, 146, 104, 0.6);
  }

  .wrap {
    width: min(1120px, 96vw);
    margin: 0 auto;
    min-height: 68px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    grid-column: 1;
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-heading);
    color: var(--ink-1);
    text-decoration: none;
  }

  .brand-mark {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid rgba(177, 146, 104, 0.8);
    box-shadow: 0 2px 8px rgba(52, 38, 26, 0.2);
  }

  .brand-mark.is-freestanding {
    width: 44px;
    height: auto;
    border-radius: 0 !important;
    object-fit: contain;
    border: 0 !important;
    box-shadow: none !important;
    background: transparent;
  }

  .brand-text {
    font-size: 1.1rem;
  }

  .nav-toggle,
  .submenu-toggle {
    display: none;
  }

  /* Header-Varianten je Modus (nur im Portal-Kontext) */
  :global(body.portal-welcome) .site-header.mode-it {
    background: rgba(66, 49, 33, 0.95);
    border-bottom-color: rgba(212, 183, 145, 0.28);
  }

  :global(body.portal-welcome) .site-header.mode-ot {
    background: rgba(10, 7, 5, 0.96);
    border-bottom-color: rgba(244, 233, 215, 0.12);
  }

  /* Rechte Header-Aktionen: Suche + IT/OT-Umschalter */
  .header-actions {
    grid-column: 3;
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  .header-search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.34rem 0.6rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--ink-2) 34%, transparent);
    background: color-mix(in srgb, var(--ink-2) 8%, transparent);
    color: var(--ink-2);
    font: 600 0.82rem/1 var(--font-ui);
    cursor: pointer;
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
  }

  .header-search-trigger:hover,
  .header-search-trigger:focus-visible {
    border-color: rgba(159, 72, 39, 0.6);
    color: var(--brand-1);
  }

  .header-search-kbd {
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    opacity: 0.75;
  }

  :global(body.portal-welcome) .header-search-trigger {
    border-color: rgba(244, 233, 215, 0.28);
    background: rgba(244, 233, 215, 0.08);
    color: rgba(244, 233, 215, 0.88);
  }

  :global(body.portal-welcome) .header-search-trigger:hover,
  :global(body.portal-welcome) .header-search-trigger:focus-visible {
    border-color: rgba(230, 155, 107, 0.6);
    color: rgba(244, 233, 215, 0.98);
  }

  .header-mode-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
  }

  .header-mode-switch .mode-label {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-2);
    opacity: 0.55;
    transition: opacity 160ms ease;
  }

  :global(body.portal-welcome) .header-mode-switch .mode-label {
    color: rgba(244, 233, 215, 0.9);
  }

  .site-header.mode-it .header-mode-switch .mode-label[data-mode='it'],
  .site-header.mode-ot .header-mode-switch .mode-label[data-mode='ot'] {
    opacity: 1;
  }

  .header-mode-switch .switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 26px;
  }

  .header-mode-switch .switch input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    opacity: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .header-mode-switch .slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background: rgba(212, 183, 145, 0.3);
    border: 1px solid rgba(177, 146, 104, 0.62);
    border-radius: 999px;
    transition: background-color 160ms ease, border-color 160ms ease;
  }

  .header-mode-switch .slider::before {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    left: 3px;
    top: 3px;
    border-radius: 999px;
    background: linear-gradient(120deg, #8a5a2b, #b1794a);
    transition: transform 160ms ease, background 160ms ease;
    box-shadow: 0 1px 5px rgba(52, 38, 26, 0.24);
  }

  .header-mode-switch .switch input:checked + .slider {
    background: rgba(248, 0, 0, 0.18);
    border-color: rgba(248, 0, 0, 0.4);
  }

  .header-mode-switch .switch input:checked + .slider::before {
    transform: translateX(24px);
    background: var(--crest-red);
  }

  .header-mode-switch .switch input:focus-visible + .slider {
    outline: 3px solid rgba(255, 255, 255, 0.7);
    outline-offset: 3px;
  }

  nav {
    grid-column: 2;
    justify-self: center;
  }

  nav > ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.2rem;
  }

  nav a {
    font-family: var(--font-ui);
    padding: 0.42rem 0.66rem;
    border-radius: 999px;
    color: var(--ink-1);
    font-size: 0.94rem;
  }

  .site-header.is-dense-nav .wrap {
    width: min(1400px, 99vw);
    display: flex;
    justify-content: flex-start;
    gap: 0.55rem;
  }

  .site-header.is-dense-nav .brand {
    grid-column: auto;
    flex: 0 0 auto;
  }

  .site-header.is-dense-nav nav {
    grid-column: auto;
    justify-self: auto;
    flex: 1 1 auto;
    width: auto;
    overflow: visible;
    margin-left: 2rem;
  }

  .site-header.is-dense-nav nav > ul {
    justify-content: flex-start;
    flex-wrap: nowrap;
    min-width: 0;
    gap: 0.7rem;
  }

  .site-header.is-dense-nav nav a {
    padding: 0.24rem 0.3rem;
    font-size: 16px;
    white-space: nowrap;
  }

  :global(body.portal-welcome) .site-header:not(.is-dense-nav) .wrap {
    width: 100%;
    padding-inline: 0.5rem;
  }

  :global(body.portal-welcome.portal-it) .site-header.is-dense-nav .wrap {
    width: 100%;
    padding-inline: 0.5rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  :global(body.portal-welcome.portal-it) .site-header.is-dense-nav .brand {
    grid-column: 1;
    justify-self: start;
  }

  :global(body.portal-welcome.portal-it) .site-header.is-dense-nav nav {
    grid-column: 2;
    justify-self: center;
    flex: 0 1 auto;
    width: auto;
    margin-left: 0;
  }

  :global(body.portal-welcome.portal-it) .site-header.is-dense-nav nav > ul {
    justify-content: center;
  }

  .site-header.is-dense-nav .header-actions {
    flex: 0 0 auto;
    margin-left: auto;
  }

  :global(body.portal-welcome.portal-it) .site-header.is-dense-nav .header-actions {
    margin-left: 0;
  }

  nav > ul > li {
    position: relative;
  }

  .nav-item-row {
    display: flex;
    align-items: center;
  }

  nav .submenu {
    position: absolute;
    left: 0;
    top: calc(100% - 1px);
    z-index: 35;
    display: none;
    min-width: 330px;
    list-style: none;
    margin: 0;
    padding: 0.36rem;
    border-radius: 10px;
    border: 1px solid rgba(244, 233, 215, 0.22);
    background: rgba(10, 7, 5, 0.97);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.34);
  }

  nav .submenu li + li {
    margin-top: 0.12rem;
  }

  nav .submenu-overview {
    display: none;
  }

  nav .submenu a {
    display: block;
    font-size: 0.9rem;
    line-height: 1.28;
    padding: 0.46rem 0.56rem;
    border-radius: 8px;
    white-space: normal;
    color: rgba(244, 233, 215, 0.96);
  }

  nav > ul > li.has-children:hover > .submenu,
  nav > ul > li.has-children:focus-within > .submenu {
    display: block;
  }

  nav a:hover,
  nav a.active {
    text-decoration: none;
    background: rgba(159, 72, 39, 0.13);
  }

  @media (max-width: 980px) {
    :global(body.mobile-nav-open) {
      overflow: hidden;
    }

    .site-header {
      position: fixed;
      inset: 0 0 auto;
      width: 100%;
      box-shadow: 0 4px 18px rgba(29, 19, 12, 0.18);
    }

    :global(body.portal-welcome) .site-header {
      --header-ink: rgba(244, 233, 215, 0.96);
      --header-panel: rgba(10, 7, 5, 0.99);
    }

    :global(body.portal-welcome.portal-it) .site-header {
      --header-panel: rgba(66, 49, 33, 0.99);
    }

    .wrap,
    .site-header.is-dense-nav .wrap,
    :global(body.portal-welcome.portal-it) .site-header.is-dense-nav .wrap {
      width: 100%;
      min-height: 64px;
      padding:
        calc(0.5rem + env(safe-area-inset-top))
        max(0.75rem, env(safe-area-inset-right))
        0.5rem
        max(0.75rem, env(safe-area-inset-left));
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
    }

    .brand,
    .site-header.is-dense-nav .brand,
    :global(body.portal-welcome.portal-it) .site-header.is-dense-nav .brand {
      grid-column: 1;
      min-width: 0;
      max-width: 100%;
      justify-self: start;
    }

    .brand-text {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .nav-toggle {
      grid-column: 2;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      min-width: 44px;
      min-height: 44px;
      padding: 0.5rem 0.7rem;
      border: 1px solid color-mix(in srgb, var(--header-ink) 36%, transparent);
      border-radius: 999px;
      background: color-mix(in srgb, var(--header-ink) 10%, transparent);
      color: var(--header-ink);
      font: 600 0.95rem/1 var(--font-ui);
      cursor: pointer;
    }

    .nav-toggle-icon,
    .nav-toggle-icon::before,
    .nav-toggle-icon::after {
      display: block;
      width: 1.2rem;
      height: 2px;
      border-radius: 999px;
      background: currentColor;
      transition: transform 160ms ease, opacity 160ms ease;
    }

    .nav-toggle-icon {
      position: relative;
    }

    .nav-toggle-icon::before,
    .nav-toggle-icon::after {
      content: '';
      position: absolute;
      left: 0;
    }

    .nav-toggle-icon::before {
      top: -0.38rem;
    }

    .nav-toggle-icon::after {
      top: 0.38rem;
    }

    .site-header.nav-open .nav-toggle-icon {
      background: transparent;
    }

    .site-header.nav-open .nav-toggle-icon::before {
      top: 0;
      transform: rotate(45deg);
    }

    .site-header.nav-open .nav-toggle-icon::after {
      top: 0;
      transform: rotate(-45deg);
    }

    nav,
    .site-header.is-dense-nav nav,
    :global(body.portal-welcome.portal-it) .site-header.is-dense-nav nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 30;
      display: none;
      width: 100%;
      max-height: calc(100dvh - var(--site-header-height, 76px));
      margin: 0;
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
      border-top: 1px solid color-mix(in srgb, var(--header-ink) 18%, transparent);
      border-bottom: 1px solid color-mix(in srgb, var(--header-ink) 18%, transparent);
      background: var(--header-panel);
      box-shadow: 0 18px 28px rgba(0, 0, 0, 0.28);
    }

    .site-header.nav-open nav,
    .site-header.is-dense-nav.nav-open nav,
    :global(body.portal-welcome.portal-it) .site-header.is-dense-nav.nav-open nav {
      display: block;
    }

    nav > ul,
    .site-header.is-dense-nav nav > ul,
    :global(body.portal-welcome.portal-it) .site-header.is-dense-nav nav > ul {
      display: block;
      width: min(100%, 42rem);
      min-width: 0;
      margin: 0 auto;
      padding: 0.5rem max(0.75rem, env(safe-area-inset-right)) calc(1rem + env(safe-area-inset-bottom)) max(0.75rem, env(safe-area-inset-left));
    }

    nav > ul > li + li {
      border-top: 1px solid color-mix(in srgb, var(--header-ink) 14%, transparent);
    }

    .nav-item-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: stretch;
    }

    nav a,
    .site-header.is-dense-nav nav a {
      display: flex;
      align-items: center;
      min-height: 48px;
      padding: 0.7rem 0.8rem;
      border-radius: 10px;
      color: var(--header-ink);

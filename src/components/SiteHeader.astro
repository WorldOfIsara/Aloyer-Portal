---
import type { NavItem } from '../data/site';

interface Props {
  nav: NavItem[];
}

const { nav } = Astro.props;
const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/portal" aria-label="Zur Startseite">
      <img
        class="brand-mark"
        src="/logos/haubentaucher-wappen.jpg"
        alt="Haubentaucher Logo"
        loading="eager"
        decoding="async"
      />
      <span class="brand-text">Aloy Portal</span>
    </a>
    <nav aria-label="Hauptnavigation">
      <ul>
        {
          nav.map((item) => {
            const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
            return (
              <li>
                <a href={item.href} aria-current={active ? 'page' : undefined} class={active ? 'active' : ''}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(246, 238, 224, 0.9);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(177, 146, 104, 0.6);
  }

  .wrap {
    width: min(1120px, 96vw);
    margin: 0 auto;
    min-height: 68px;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-heading);
    color: var(--ink-1);
    text-decoration: none;
  }

  .brand-mark {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid rgba(177, 146, 104, 0.8);
    box-shadow: 0 2px 8px rgba(52, 38, 26, 0.2);
  }

  .brand-text {
    font-size: 1.1rem;
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.2rem;
  }

  nav a {
    font-family: var(--font-ui);
    padding: 0.42rem 0.66rem;
    border-radius: 999px;
    color: var(--ink-1);
    font-size: 0.94rem;
  }

  nav a:hover,
  nav a.active {
    text-decoration: none;
    background: rgba(159, 72, 39, 0.13);
  }

  @media (max-width: 980px) {
    .wrap {
      grid-template-columns: 1fr;
      padding: 0.6rem 0;
      gap: 0.5rem;
      justify-items: center;
    }

    nav ul {
      justify-content: center;
    }
  }
</style>

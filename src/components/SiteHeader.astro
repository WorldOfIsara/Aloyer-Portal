---
import type { NavItem } from '../data/site';

interface Props {
  nav: NavItem[];
  brandText?: string;
  brandLogoSrc?: string;
  brandLogoAlt?: string;
  brandLogoFreestanding?: boolean;
}

const {
  nav,
  brandText = 'Aloy Portal',
  brandLogoSrc = '/logos/haubentaucher-wappen.jpg',
  brandLogoAlt = 'Haubentaucher Logo',
  brandLogoFreestanding = false,
} = Astro.props;
const pathname = Astro.url.pathname;
const isDenseNav = nav.length >= 9;
---

<header class:list={['site-header', { 'is-dense-nav': isDenseNav }]}>
  <div class:list={['wrap', { 'is-dense-nav': isDenseNav }]}>
    <a class="brand" href="/portal" aria-label="Zur Startseite">
      <img
        class:list={['brand-mark', { 'is-freestanding': brandLogoFreestanding }]}
        src={brandLogoSrc}
        alt={brandLogoAlt}
        loading="eager"
        decoding="async"
      />
      <span class="brand-text">{brandText}</span>
    </a>
    <nav class:list={{ 'is-dense-nav': isDenseNav }} aria-label="Hauptnavigation">
      <ul class:list={{ 'is-dense-nav': isDenseNav }}>
        {
          nav.map((item) => {
            const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
            return (
              <li>
                <a href={item.href} aria-current={active ? 'page' : undefined} class={active ? 'active' : ''}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(246, 238, 224, 0.9);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid rgba(177, 146, 104, 0.6);
  }

  .wrap {
    width: min(1120px, 96vw);
    margin: 0 auto;
    min-height: 68px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    grid-column: 1;
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-heading);
    color: var(--ink-1);
    text-decoration: none;
  }

  .brand-mark {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid rgba(177, 146, 104, 0.8);
    box-shadow: 0 2px 8px rgba(52, 38, 26, 0.2);
  }

  .brand-mark.is-freestanding {
    width: 44px;
    height: auto;
    border-radius: 0 !important;
    object-fit: contain;
    border: 0 !important;
    box-shadow: none !important;
    background: transparent;
  }

  .brand-text {
    font-size: 1.1rem;
  }

  nav {
    grid-column: 2;
    justify-self: center;
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.2rem;
  }

  nav a {
    font-family: var(--font-ui);
    padding: 0.42rem 0.66rem;
    border-radius: 999px;
    color: var(--ink-1);
    font-size: 0.94rem;
  }

  .site-header.is-dense-nav .wrap {
    width: min(1400px, 99vw);
    display: flex;
    justify-content: flex-start;
    gap: 0.55rem;
  }

  .site-header.is-dense-nav .brand {
    grid-column: auto;
    flex: 0 0 auto;
  }

  .site-header.is-dense-nav nav {
    grid-column: auto;
    justify-self: auto;
    flex: 1 1 auto;
    width: auto;
    overflow: hidden;
    margin-left: 2rem;
  }

  .site-header.is-dense-nav nav ul {
    justify-content: flex-start;
    flex-wrap: nowrap;
    min-width: 0;
    gap: 0.3rem;
  }

  .site-header.is-dense-nav nav a {
    padding: 0.24rem 0.3rem;
    font-size: 16px;
    white-space: nowrap;
  }

  :global(body.portal-welcome) .site-header:not(.is-dense-nav) .wrap {
    width: 100%;
    padding-inline: 0.5rem;
  }

  nav a:hover,
  nav a.active {
    text-decoration: none;
    background: rgba(159, 72, 39, 0.13);
  }

  @media (max-width: 980px) {
    .wrap {
      grid-template-columns: 1fr;
      padding: 0.6rem 0;
      gap: 0.5rem;
      justify-items: center;
    }

    nav ul {
      justify-content: center;
    }
  }
</style>

---
interface CharacterFact {
  label: string;
  value: string;
}

interface CharacterNote {
  title: string;
  text: string;
}

interface Props {
  name: string;

  imageSrc?: string;
  imageAlt?: string;

  rank?: string;
  deploymentArea?: string;
  origin?: string;
  role?: string;
  formerLife?: string;
  weapons?: string;

  summary?: string;
  notes?: CharacterNote[];
}

const withBase = (path: string) => {
  if (
    path.startsWith('http://') ||
    path.startsWith('https://') ||
    path.startsWith('//') ||
    path.startsWith('#') ||
    path.startsWith('mailto:') ||
    path.startsWith('tel:') ||
    path.startsWith(import.meta.env.BASE_URL)
  ) {
    return path;
  }

  return `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
};

const {
  name,
  imageSrc,
  imageAlt,

  rank,
  deploymentArea,
  origin,
  role,
  formerLife,
  weapons,

  summary,
  notes = [],
} = Astro.props;

const altText = imageAlt ?? `Porträt von ${name}`;

const dossierFacts: CharacterFact[] = [
  ...(rank ? [{ label: 'Rang', value: rank }] : []),
  ...(deploymentArea ? [{ label: 'Einsatzort', value: deploymentArea }] : []),
  ...(origin ? [{ label: 'Herkunft', value: origin }] : []),
  ...(role ? [{ label: 'Funktion', value: role }] : []),
  ...(formerLife ? [{ label: 'Früheres Leben', value: formerLife }] : []),
  ...(weapons ? [{ label: 'Bewaffnung', value: weapons }] : []),
];
---

<article class="character-sheet">
  <section class="character-sheet__top" aria-label={`Charakterbogen zu ${name}`}>
    <figure class="character-sheet__image">
      {
        imageSrc ? (
          <img
            src={withBase(imageSrc)}
            alt={altText}
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="character-sheet__placeholder" aria-hidden="true">
            <span>{name.slice(0, 1)}</span>
          </div>
        )
      }

      
    </figure>

    <div class="character-sheet__info">
      <p class="character-sheet__kicker">Charakterbogen</p>

      <h2>{name}</h2>

      {
        summary && (
          <p class="character-sheet__summary">
            {summary}
          </p>
        )
      }

      {
        dossierFacts.length > 0 && (
          <div class="character-sheet__facts" aria-label={`Daten zu ${name}`}>
            {dossierFacts.map((fact) => (
              <div class="character-sheet__fact">
                <span class="character-sheet__fact-label">{fact.label}</span>
                <span class="character-sheet__fact-value">{fact.value}</span>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <section class="character-sheet__text">
    <slot />
  </section>

  {
    notes.length > 0 && (
      <section class="character-sheet__notes" aria-labelledby={`${name}-notizen`}>
        <h2 id={`${name}-notizen`}>Notizen</h2>

        <div class="character-sheet__notes-grid">
          {notes.map((note, index) => (
            <article
              class:list={[
                'character-note',
                `character-note--${(index % 4) + 1}`,
              ]}
            >
              <h3>{note.title}</h3>
              <p>{note.text}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }
</article>

<style>
  .character-sheet {
    display: block;
  }

  /*
    WICHTIG:
    Das erzwingt Bild links + Infos rechts.
  */
  .character-sheet__top {
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 1.5rem;
  align-items: stretch;
  margin: 1.5rem 0 2.25rem;
}

.character-sheet__image {
  margin: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.character-sheet__image img,
.character-sheet__placeholder {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 100%;
  aspect-ratio: auto;
  object-fit: cover;
  object-position: center top;
  border-radius: var(--radius-md);
  border: 1px solid rgba(92, 55, 31, 0.42);
  box-shadow: 0 12px 26px rgba(20, 11, 7, 0.24);
  background: rgba(255, 255, 255, 0.35);
}

.character-sheet__image figcaption {
  margin-top: 0.55rem;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  color: var(--ink-2);
  text-align: center;
}

.character-sheet__info {
  min-width: 0;
  height: 100%;
  padding: 1.25rem;
  border-radius: var(--radius-md);
  border: 1px solid rgba(92, 55, 31, 0.34);
  background:
    radial-gradient(circle at 12% 10%, rgba(230, 155, 107, 0.12), transparent 30%),
    radial-gradient(circle at 90% 100%, rgba(92, 55, 31, 0.1), transparent 34%),
    rgba(255, 255, 255, 0.38);
  box-shadow:
    0 10px 22px rgba(20, 11, 7, 0.12),
    inset 0 0 18px rgba(255, 248, 220, 0.14);
}



  



  .character-sheet__kicker {
    margin: 0 0 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.95);
  }

  .character-sheet__info h2 {
    margin: 0;
    padding: 0;
    text-align: left;
  }

  .character-sheet__info h2::after {
    display: none;
  }

  .character-sheet__summary {
    margin: 0.85rem 0 0;
    line-height: 1.62;
    font-weight: 650;
    color: rgba(33, 23, 15, 0.92);
  }

  /*
    WICHTIG:
    Das sind die Div-Karten rechts.
  */
  .character-sheet__facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .character-sheet__fact {
    min-height: 4.6rem;
    padding: 0.8rem 0.9rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(177, 146, 104, 0.56);
    background:
      linear-gradient(
        135deg,
        rgba(255, 248, 232, 0.72),
        rgba(230, 210, 166, 0.48)
      );
    box-shadow: inset 0 0 10px rgba(92, 55, 31, 0.06);
  }

  .character-sheet__fact-label {
    display: block;
    margin: 0 0 0.22rem;
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.92);
  }

  .character-sheet__fact-value {
    display: block;
    font-weight: 800;
    line-height: 1.35;
    color: rgba(33, 23, 15, 0.95);
  }

  .character-sheet__text {
    margin-top: 1.75rem;
  }

  .character-sheet__notes {
    margin-top: 3rem;
    padding-top: 1.5rem;
  }

  .character-sheet__notes h2 {
    text-align: center;
  }

  .character-sheet__notes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
    margin-top: 1.75rem;
  }

  .character-note {
    --note-rotation: 0deg;
    --paper-a: #ead8aa;
    --paper-b: #d1b06d;
    --paper-c: #f4e8c3;

    position: relative;
    min-height: 11.5rem;
    padding: 1.25rem 1.15rem 1.15rem;
    color: #24170d;

    background:
      radial-gradient(circle at var(--stain-x, 18%) var(--stain-y, 22%), rgba(92, 55, 31, 0.18), transparent 17%),
      radial-gradient(circle at var(--stain-2-x, 72%) var(--stain-2-y, 78%), rgba(92, 55, 31, 0.13), transparent 18%),
      radial-gradient(circle at 28% 86%, rgba(255, 255, 255, 0.18), transparent 20%),
      linear-gradient(135deg, var(--paper-c), var(--paper-a) 45%, var(--paper-b));

    border: 1px solid rgba(94, 61, 28, 0.34);
    border-radius: 0;
    clip-path: var(--note-tear);

    filter:
      drop-shadow(0 12px 16px rgba(20, 11, 7, 0.2))
      drop-shadow(0 3px 5px rgba(20, 11, 7, 0.14));

    transform: rotate(var(--note-rotation));
    isolation: isolate;
    overflow: hidden;
  }

  .character-note::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(92, 55, 31, 0.035) 1px, transparent 1px),
      linear-gradient(rgba(92, 55, 31, 0.035) 1px, transparent 1px),
      radial-gradient(circle at var(--fiber-x, 20%) var(--fiber-y, 35%), rgba(70, 43, 20, 0.14), transparent 8%);
    background-size: 19px 19px, 23px 23px, auto;
    opacity: 0.75;
  }

  .character-note::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to right, rgba(70, 43, 20, 0.16), transparent 13%, transparent 87%, rgba(70, 43, 20, 0.12)),
      linear-gradient(to bottom, rgba(70, 43, 20, 0.12), transparent 16%, transparent 84%, rgba(70, 43, 20, 0.18)),
      var(--tear-line);
    mix-blend-mode: multiply;
    opacity: 0.65;
  }

  .character-note h3 {
    position: relative;
    z-index: 1;
    margin: 0 0 0.55rem;
    padding: 0;
    text-align: left;
    font-family: var(--font-ui);
    font-size: 1rem;
    line-height: 1.25;
    color: rgba(72, 42, 20, 0.98);
  }

  .character-note h3::after {
    display: none;
  }

  .character-note p {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    font-weight: 650;
    color: rgba(33, 23, 15, 0.95);
  }

  .character-note--1 {
    --note-rotation: -2deg;
    --paper-a: #ead7a5;
    --paper-b: #cfaf68;
    --paper-c: #f5e9c6;
    --stain-x: 18%;
    --stain-y: 24%;
    --stain-2-x: 75%;
    --stain-2-y: 80%;
    --fiber-x: 22%;
    --fiber-y: 38%;
    --note-tear: polygon(
      0 4%, 5% 0, 12% 3%, 21% 1%, 33% 4%, 44% 0,
      56% 3%, 67% 1%, 79% 4%, 90% 1%, 100% 3%,
      97% 17%, 100% 31%, 96% 45%, 100% 61%,
      97% 75%, 100% 89%, 96% 100%,
      84% 97%, 71% 100%, 58% 96%, 45% 100%,
      33% 97%, 20% 100%, 8% 96%, 0 99%,
      3% 84%, 0 69%, 4% 55%, 0 39%, 3% 24%
    );
    --tear-line:
      linear-gradient(116deg, transparent 0 46%, rgba(70, 43, 20, 0.24) 47% 50%, transparent 51% 100%)
      10% 22% / 34% 20% no-repeat;
  }

  .character-note--2 {
    --note-rotation: 1.6deg;
    --paper-a: #e0c486;
    --paper-b: #bd9350;
    --paper-c: #edd9a9;
    --stain-x: 64%;
    --stain-y: 28%;
    --stain-2-x: 26%;
    --stain-2-y: 76%;
    --fiber-x: 58%;
    --fiber-y: 40%;
    --note-tear: polygon(
      2% 0, 13% 3%, 25% 1%, 38% 4%, 50% 0,
      61% 2%, 73% 0, 85% 3%, 97% 0, 100% 6%,
      95% 16%, 100% 27%, 94% 39%, 100% 52%,
      95% 64%, 100% 78%, 93% 91%, 99% 100%,
      86% 96%, 73% 100%, 62% 97%, 49% 100%,
      37% 96%, 24% 100%, 12% 97%, 0 100%,
      2% 86%, 0 73%, 3% 59%, 0 44%, 2% 29%, 0 13%
    );
    --tear-line:
      linear-gradient(45deg, transparent 0 47%, rgba(70, 43, 20, 0.22) 48% 50%, transparent 51% 100%)
      70% 18% / 24% 22% no-repeat;
  }

  .character-note--3 {
    --note-rotation: -0.8deg;
    --paper-a: #ebd6a7;
    --paper-b: #d5bb78;
    --paper-c: #f8edcf;
    --stain-x: 34%;
    --stain-y: 20%;
    --stain-2-x: 82%;
    --stain-2-y: 68%;
    --fiber-x: 44%;
    --fiber-y: 55%;
    --note-tear: polygon(
      0 2%, 10% 0, 21% 2%, 32% 0, 44% 3%, 55% 1%,
      68% 3%, 80% 0, 91% 2%, 100% 1%,
      98% 15%, 100% 29%, 97% 43%, 100% 57%,
      98% 71%, 100% 84%, 95% 100%,
      82% 94%, 70% 100%, 58% 93%, 45% 100%,
      33% 94%, 20% 100%, 8% 95%, 0 98%,
      1% 82%, 0 68%, 2% 53%, 0 38%, 2% 23%, 0 10%
    );
    --tear-line:
      linear-gradient(90deg, transparent 0 47%, rgba(70, 43, 20, 0.2) 48% 50%, transparent 51% 100%)
      46% 82% / 36% 14% no-repeat;
  }

  .character-note--4 {
    --note-rotation: 2.2deg;
    --paper-a: #dcbf80;
    --paper-b: #ba8f49;
    --paper-c: #efdfb2;
    --stain-x: 76%;
    --stain-y: 18%;
    --stain-2-x: 22%;
    --stain-2-y: 84%;
    --fiber-x: 18%;
    --fiber-y: 60%;
    --note-tear: polygon(
      0 6%, 7% 1%, 17% 4%, 29% 0, 41% 2%, 53% 0,
      66% 4%, 78% 1%, 90% 3%, 100% 0,
      96% 12%, 100% 25%, 97% 39%, 100% 54%,
      96% 68%, 100% 82%, 97% 100%,
      84% 98%, 72% 100%, 60% 96%, 48% 100%,
      35% 97%, 23% 100%, 10% 94%, 0 100%,
      5% 86%, 0 72%, 4% 57%, 0 43%, 3% 29%, 0 16%
    );
    --tear-line:
      linear-gradient(62deg, transparent 0 47%, rgba(70, 43, 20, 0.24) 48% 50%, transparent 51% 100%)
      12% 76% / 30% 20% no-repeat;
  }

  @media (max-width: 850px) {
  .character-sheet__top {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .character-sheet__image {
    max-width: 300px;
    height: auto;
    margin-inline: auto;
  }

  .character-sheet__image img,
  .character-sheet__placeholder {
    height: auto;
    aspect-ratio: 3 / 4;
  }
}

  @media (max-width: 620px) {
    .character-sheet__facts {
      grid-template-columns: 1fr;
    }

    .character-sheet__notes-grid {
      grid-template-columns: 1fr;
    }

    .character-note {
      transform: none;
    }
  }
</style>
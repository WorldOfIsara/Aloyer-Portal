---
import TextDivider from './TextDivider.astro';

interface CharacterFact {
  label: string;
  value: string;
}

interface CharacterNote {
  title: string;
  text: string;
}

interface Props {
  name: string;

  imageSrc?: string;
  imageAlt?: string;

  rank?: string;
  deploymentArea?: string;
  origin?: string;
  role?: string;
  formerLife?: string;
  weapons?: string;

  summary?: string;
  notes?: CharacterNote[];
}

const withBase = (path: string) => {
  if (
    path.startsWith('http://') ||
    path.startsWith('https://') ||
    path.startsWith('//') ||
    path.startsWith('#') ||
    path.startsWith('mailto:') ||
    path.startsWith('tel:') ||
    path.startsWith(import.meta.env.BASE_URL)
  ) {
    return path;
  }

  return `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
};

const {
  name,
  imageSrc,
  imageAlt,

  rank,
  deploymentArea,
  origin,
  role,
  formerLife,
  weapons,

  summary,
  notes = [],
} = Astro.props;

const altText = imageAlt ?? `Porträt von ${name}`;

// Zufällige, aber wiederholungsarme Verteilung der 4 Zettel-Varianten:
// pro Vierer-Block wird [1,2,3,4] neu gemischt (Fisher-Yates), sodass
// jede Variante innerhalb eines Blocks genau einmal vorkommt, statt
// stur im Kreis 1-2-3-4-1-2-3-4 zu wiederholen. Läuft serverseitig
// beim Build, daher kein Layout-Shift und kein Hydration-Mismatch.
function shuffledNoteVariants(count: number): number[] {
  const variants: number[] = [];

  while (variants.length < count) {
    const batch = [1, 2, 3, 4];

    for (let i = batch.length - 1; i > 0; i -= 1) {
      const j = Math.floor(Math.random() * (i + 1));
      [batch[i], batch[j]] = [batch[j], batch[i]];
    }

    // Direkten Übergang "...4 | 4..." zwischen zwei Blöcken vermeiden.
    const previous = variants[variants.length - 1];
    if (previous !== undefined && batch[0] === previous) {
      const swapWith = 1 + Math.floor(Math.random() * (batch.length - 1));
      [batch[0], batch[swapWith]] = [batch[swapWith], batch[0]];
    }

    variants.push(...batch);
  }

  return variants.slice(0, count);
}

const noteVariants = shuffledNoteVariants(notes.length);

const dossierFacts: CharacterFact[] = [
  { label: 'Rang', value: rank ?? '-' },
  { label: 'Herkunft', value: origin ?? '-' },
  { label: 'Funktion', value: role ?? '-' },
  { label: 'Bewaffnung', value: weapons ?? '-' },
];
---

<article class="character-sheet">
  <section class="character-sheet__top" aria-label={`Charakterbogen zu ${name}`}>
    <figure class="character-sheet__image">
      {
        imageSrc ? (
          <img
            src={withBase(imageSrc)}
            alt={altText}
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="character-sheet__placeholder" aria-hidden="true">
            <span>{name.slice(0, 1)}</span>
          </div>
        )
      }

      
    </figure>

    <div class="character-sheet__info">
      <p class="character-sheet__kicker">Charakterbogen</p>

      <h2>{name}</h2>

      {
        summary && (
          <p class="character-sheet__summary">
            {summary}
          </p>
        )
      }

      {
        dossierFacts.length > 0 && (
          <div class="character-sheet__facts" aria-label={`Daten zu ${name}`}>
            {dossierFacts.map((fact) => (
              <div class="character-sheet__fact">
                <span class="character-sheet__fact-label">{fact.label}</span>
                <span class="character-sheet__fact-value">{fact.value}</span>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>
  <section class="character-sheet__text">
    <slot />
  </section>

  {
    notes.length > 0 && (
      <section class="character-sheet__notes" aria-labelledby={`${name}-notizen`}>
        <h2 id={`${name}-notizen`}>Notizen</h2>

        <div class="character-sheet__notes-grid">
          {notes.map((note, index) => (
            <article
              class:list={[
                'character-note',
                `character-note--${noteVariants[index]}`,
              ]}
              style={`--note-image: url('${withBase(`/images/it/helper/Note${noteVariants[index]}.webp`)}');`}
              data-fit-note
            >
              
              <div class="character-note__body" data-fit-note-body>
                <h3>{note.title}</h3>
                <p>{note.text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )
  }
</article>

<script>
  const MIN_SCALE = 0.55;
  const STEP = 0.05;

  function fitNoteText(note: HTMLElement) {
    const body = note.querySelector<HTMLElement>('[data-fit-note-body]');
    if (!body) return;

    let scale = 1;
    body.style.setProperty('--note-text-scale', '1');

    // Erst zurücksetzen, dann schrittweise verkleinern, bis der Text
    // wieder vollständig innerhalb des Zettels liegt.
    while (scale > MIN_SCALE && body.scrollHeight > body.clientHeight + 1) {
      scale = Math.round((scale - STEP) * 100) / 100;
      body.style.setProperty('--note-text-scale', String(scale));
    }
  }

  function fitAllNotes() {
    document.querySelectorAll<HTMLElement>('[data-fit-note]').forEach(fitNoteText);
  }

  let resizeTimer: number | undefined;
  function scheduleFit() {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(fitAllNotes, 120);
  }

  fitAllNotes();
  document.fonts?.ready.then(fitAllNotes);
  window.addEventListener('resize', scheduleFit);
  document.addEventListener('astro:page-load', fitAllNotes);
</script>

<style>
  .character-sheet {
    display: block;
  }

  /*
    WICHTIG:
    Das erzwingt Bild links + Infos rechts.
  */
  .character-sheet__top {
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 1.5rem;
  align-items: stretch;
  margin: 1.5rem 0 2.25rem;
}

.character-sheet__image {
  position: relative;
  margin: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  /* Weiße "Karte" hinter dem Bild; overflow bleibt sichtbar, damit die
     Figur seitlich/unten aus dieser Fläche ausbrechen kann (OOB-Effekt). */
  overflow: visible;
  background: #F7EFE0;
  border-radius: var(--radius-md);
  border: 1px solid rgba(92, 55, 31, 0.42);
  box-shadow: 0 12px 26px rgba(20, 11, 7, 0.24);
}

.character-sheet__placeholder {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 100%;
  border-radius: var(--radius-md);
}

.character-sheet__image img {
  display: block;
  position: relative;
  z-index: 2;
  /* Bild ist breiter/höher als seine weiße Karte und nicht croppend
     (object-fit: contain) – dadurch ragt die Figur sichtbar über den
     rechten und unteren Rand der Karte hinaus, statt hart am Rahmen
     abgeschnitten zu werden. */
  width: 112%;
  max-width: 112%;
  height: 104%;
  /* Fester Abstand vom linken Rand statt Bleed nach links; der Effekt
     ist bewusst auf oben + rechts begrenzt (ragt über den Kartenrand
     nach oben und rechts über das Info-Div hinaus). */
  margin: -3% 0 0 0.4rem;
  object-fit: contain;
  object-position: left top;
  border-radius: 0;
  border: 0;
  box-shadow: none;
  background: transparent;
  filter: drop-shadow(0 16px 22px rgba(20, 11, 7, 0.32));
}

.character-sheet__image figcaption {
  margin-top: 0.55rem;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  color: var(--ink-2);
  text-align: center;
}

.character-sheet__info {
  min-width: 0;
  height: 100%;
  padding: 1.25rem;
  border-radius: var(--radius-md);
  border: 1px solid rgba(92, 55, 31, 0.34);
  background:
    radial-gradient(circle at 12% 10%, rgba(230, 155, 107, 0.12), transparent 30%),
    radial-gradient(circle at 90% 100%, rgba(92, 55, 31, 0.1), transparent 34%),
    rgba(255, 255, 255, 0.38);
  box-shadow:
    0 10px 22px rgba(20, 11, 7, 0.12),
    inset 0 0 18px rgba(255, 248, 220, 0.14);
}



  



  .character-sheet__kicker {
    margin: 0 0 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.95);
  }

  .character-sheet__info h2 {
    margin: 0;
    padding: 0;
    text-align: left;
  }

  .character-sheet__info h2::after {
    display: none;
  }

  .character-sheet__summary {
    /*
      Wie bei den Fact-Boxen: feste Höhe statt frei wachsend, sonst
      schiebt eine lange Beschreibung die Facts weiter nach unten und
      das Info-Div wird von Charakter zu Charakter unterschiedlich hoch.
      Überlanger Text wird nach 3 Zeilen abgeschnitten.
    */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: calc(1.62em * 3);
    margin: 0.85rem 0 0;
    line-height: 1.62;
    font-weight: 650;
    color: rgba(33, 23, 15, 0.92);
  }

  /*
    WICHTIG:
    Das sind die Div-Karten rechts.
  */
  .character-sheet__facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .character-sheet__fact {
    /*
      WICHTIG: feste Höhe statt min-height. Sonst wächst die Box mit der
      Textmenge im Wert (z. B. langer "Einsatzort"-Text), wodurch das
      ganze rechte Info-Div von Charakter zu Charakter unterschiedlich
      hoch wird. Überlanger Text wird stattdessen im Wert selbst
      abgeschnitten (siehe .character-sheet__fact-value).
    */
    height: 4.6rem;
    padding: 0.8rem 0.9rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(177, 146, 104, 0.56);
    background:
      linear-gradient(
        135deg,
        rgba(255, 248, 232, 0.72),
        rgba(230, 210, 166, 0.48)
      );
    box-shadow: inset 0 0 10px rgba(92, 55, 31, 0.06);
  }

  .character-sheet__fact-label {
    display: block;
    margin: 0 0 0.22rem;
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.92);
  }

  .character-sheet__fact-value {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 800;
    line-height: 1.35;
    color: rgba(33, 23, 15, 0.95);
  }

  .character-sheet__text {
    margin-top: 1.75rem;
  }

  .character-sheet__notes {
    margin-top: 3rem;
    padding-top: 1.5rem;
  }

  .character-sheet__notes h2 {
    text-align: center;
  }

  .character-sheet__notes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: start;
    gap: 1.4rem;
    margin-top: 1.75rem;
  }

  .character-note {
    --note-rotation: 0deg;
    --note-image: none;
    --note-text-scale: 1;

    position: relative;
    box-sizing: border-box;
    width: 100%;
    aspect-ratio: var(--note-aspect, 1 / 1);
    /*
      WICHTIG: padding-top/bottom bezieht sich in CSS immer auf die
      BREITE des Elements, nie auf die eigene Höhe. Bei stark
      unterschiedlichen Seitenverhältnissen muss der vertikale Wert
      daher pro Variante umgerechnet werden (siehe --note-pad-block
      weiter unten), sonst wäre bei einem breiten/flachen Zettel wie
      Note 4 das Padding absolut viel zu groß.
    */
    padding-inline: 9%;
    padding-top: var(--note-pad-top, var(--note-pad-block, 10%));
    padding-bottom: var(--note-pad-bottom, var(--note-pad-block, 10%));
    color: #24170d;

    background-image: var(--note-image);
    background-size: 100% 100%;
    background-repeat: no-repeat;
    background-position: center;

    filter:
      drop-shadow(0 4px 5px rgba(20, 11, 7, 0.22))
      drop-shadow(0 14px 18px rgba(20, 11, 7, 0.28));

    transform: rotate(var(--note-rotation));
  }

  .character-note__body {
    height: 100%;
    overflow: hidden;
    font-size: calc(1rem * var(--note-text-scale, 1));
  }

  .character-note h3 {
    position: relative;
    z-index: 1;
    margin: 0 0 0.55em;
    padding: 0;
    text-align: left;
    font-family: var(--font-ui);
    font-size: 1.05em;
    line-height: 1.25;
    color: rgba(72, 42, 20, 0.98);
    overflow-wrap: break-word;
  }

  .character-note h3::after {
    display: none;
  }

  .character-note p {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 0.95em;
    line-height: 1.5;
    font-weight: 650;
    color: rgba(33, 23, 15, 0.95);
    overflow-wrap: break-word;
  }

  .character-note--1 {
    --note-rotation: -2.4deg;
    --note-aspect: 982 / 939;
    --note-pad-block: 10%;
  }

  .character-note--2 {
    --note-rotation: 1.8deg;
    --note-aspect: 948 / 916;
    --note-pad-block: 10%;
  }

  .character-note--3 {
    --note-rotation: -1.3deg;
    --note-aspect: 719 / 1022;
    --note-pad-block: 14%;
    /* Zettel hat oben einen Knick/umgeschlagene Ecke – Text startet
       daher zusätzlich ~10% der Höhe tiefer, damit nichts über den
       Knick läuft. */
    --note-pad-top: 28%;
  }

  .character-note--4 {
    --note-rotation: 2.6deg;
    --note-aspect: 1006 / 367;
    --note-pad-block: 4%;
  }

  @media (max-width: 850px) {
  .character-sheet__top {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .character-sheet__image {
    max-width: 300px;
    height: auto;
    margin-inline: auto;
  }

  .character-sheet__placeholder {
    height: auto;
    aspect-ratio: 3 / 4;
  }

  .character-sheet__image img {
    width: 116%;
    max-width: 116%;
    height: auto;
    aspect-ratio: 3 / 4;
    margin: -5% 0 0 0.85rem;
  }
}

  @media (max-width: 620px) {
    .character-sheet__facts {
      grid-template-columns: 1fr;
    }

    .character-sheet__notes-grid {
      grid-template-columns: 1fr;
    }

    .character-note {
      transform: none;
    }
  }
</style>
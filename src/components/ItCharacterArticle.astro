---
interface CharacterFact {
  label: string;
  value: string;
}

interface CharacterNote {
  title: string;
  text: string;
}

interface Props {
  name: string;

  imageSrc?: string;
  imageAlt?: string;

  rank?: string;
  deploymentArea?: string;
  origin?: string;
  role?: string;
  formerLife?: string;
  weapons?: string;

  summary?: string;
  notes?: CharacterNote[];
}

const withBase = (path: string) => {
  if (
    path.startsWith('http://') ||
    path.startsWith('https://') ||
    path.startsWith('//') ||
    path.startsWith('#') ||
    path.startsWith('mailto:') ||
    path.startsWith('tel:') ||
    path.startsWith(import.meta.env.BASE_URL)
  ) {
    return path;
  }

  return `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
};

const {
  name,
  imageSrc,
  imageAlt,

  rank,
  deploymentArea,
  origin,
  role,
  formerLife,
  weapons,

  summary,
  notes = [],
} = Astro.props;

const altText = imageAlt ?? `Porträt von ${name}`;

const dossierFacts: CharacterFact[] = [
  { label: 'Rang', value: rank ?? '-' },
  { label: 'Einsatzort', value: deploymentArea ?? '-' },
  { label: 'Herkunft', value: origin ?? '-' },
  { label: 'Funktion', value: role ?? '-' },
  { label: 'Früheres Leben', value: formerLife ?? '-' },
  { label: 'Bewaffnung', value: weapons ?? '-' },
];
---

<article class="character-sheet">
  <section class="character-sheet__top" aria-label={`Charakterbogen zu ${name}`}>
    <figure class="character-sheet__image">
      {
        imageSrc ? (
          <img
            src={withBase(imageSrc)}
            alt={altText}
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="character-sheet__placeholder" aria-hidden="true">
            <span>{name.slice(0, 1)}</span>
          </div>
        )
      }

      
    </figure>

    <div class="character-sheet__info">
      <p class="character-sheet__kicker">Charakterbogen</p>

      <h2>{name}</h2>

      {
        summary && (
          <p class="character-sheet__summary">
            {summary}
          </p>
        )
      }

      {
        dossierFacts.length > 0 && (
          <div class="character-sheet__facts" aria-label={`Daten zu ${name}`}>
            {dossierFacts.map((fact) => (
              <div class="character-sheet__fact">
                <span class="character-sheet__fact-label">{fact.label}</span>
                <span class="character-sheet__fact-value">{fact.value}</span>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <section class="character-sheet__text">
    <slot />
  </section>

  {
    notes.length > 0 && (
      <section class="character-sheet__notes" aria-labelledby={`${name}-notizen`}>
        <svg aria-hidden="true" focusable="false" class="note-filter-defs">
          <filter id="note-paper-grain" x="-20%" y="-20%" width="140%" height="140%">
            <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="4" stitchTiles="stitch" result="grain" />
            <feColorMatrix in="grain" type="matrix" values="0 0 0 0 0.14  0 0 0 0 0.09  0 0 0 0 0.04  0 0 0 0.55 0" />
          </filter>
          <filter id="note-paper-fiber" x="-20%" y="-20%" width="140%" height="140%">
            <feTurbulence type="turbulence" baseFrequency="0.012 0.09" numOctaves="2" seed="9" result="fiber" />
            <feColorMatrix in="fiber" type="matrix" values="0 0 0 0 0.24  0 0 0 0 0.15  0 0 0 0 0.06  0 0 0 0.4 0" />
          </filter>
        </svg>
        <h2 id={`${name}-notizen`}>Notizen</h2>

        <div class="character-sheet__notes-grid">
          {notes.map((note, index) => (
            <article
              class:list={[
                'character-note',
                `character-note--${(index % 4) + 1}`,
              ]}
            >
              <h3>{note.title}</h3>
              <p>{note.text}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }
</article>

<style>
  .character-sheet {
    display: block;
  }

  /*
    WICHTIG:
    Das erzwingt Bild links + Infos rechts.
  */
  .character-sheet__top {
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 1.5rem;
  align-items: stretch;
  margin: 1.5rem 0 2.25rem;
}

.character-sheet__image {
  margin: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.character-sheet__image img,
.character-sheet__placeholder {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 100%;
  aspect-ratio: auto;
  object-fit: cover;
  object-position: center top;
  border-radius: var(--radius-md);
  border: 1px solid rgba(92, 55, 31, 0.42);
  box-shadow: 0 12px 26px rgba(20, 11, 7, 0.24);
  background: rgba(255, 255, 255, 0.35);
}

.character-sheet__image figcaption {
  margin-top: 0.55rem;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  color: var(--ink-2);
  text-align: center;
}

.character-sheet__info {
  min-width: 0;
  height: 100%;
  padding: 1.25rem;
  border-radius: var(--radius-md);
  border: 1px solid rgba(92, 55, 31, 0.34);
  background:
    radial-gradient(circle at 12% 10%, rgba(230, 155, 107, 0.12), transparent 30%),
    radial-gradient(circle at 90% 100%, rgba(92, 55, 31, 0.1), transparent 34%),
    rgba(255, 255, 255, 0.38);
  box-shadow:
    0 10px 22px rgba(20, 11, 7, 0.12),
    inset 0 0 18px rgba(255, 248, 220, 0.14);
}



  



  .character-sheet__kicker {
    margin: 0 0 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.95);
  }

  .character-sheet__info h2 {
    margin: 0;
    padding: 0;
    text-align: left;
  }

  .character-sheet__info h2::after {
    display: none;
  }

  .character-sheet__summary {
    margin: 0.85rem 0 0;
    line-height: 1.62;
    font-weight: 650;
    color: rgba(33, 23, 15, 0.92);
  }

  /*
    WICHTIG:
    Das sind die Div-Karten rechts.
  */
  .character-sheet__facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .character-sheet__fact {
    min-height: 4.6rem;
    padding: 0.8rem 0.9rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(177, 146, 104, 0.56);
    background:
      linear-gradient(
        135deg,
        rgba(255, 248, 232, 0.72),
        rgba(230, 210, 166, 0.48)
      );
    box-shadow: inset 0 0 10px rgba(92, 55, 31, 0.06);
  }

  .character-sheet__fact-label {
    display: block;
    margin: 0 0 0.22rem;
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.92);
  }

  .character-sheet__fact-value {
    display: block;
    font-weight: 800;
    line-height: 1.35;
    color: rgba(33, 23, 15, 0.95);
  }

  .character-sheet__text {
    margin-top: 1.75rem;
  }

  .character-sheet__notes {
    margin-top: 3rem;
    padding-top: 1.5rem;
  }

  .character-sheet__notes h2 {
    text-align: center;
  }

  .character-sheet__notes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
    margin-top: 1.75rem;
  }

  .note-filter-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }

  .character-note {
    --note-rotation: 0deg;
    --paper-a: #ead8aa;
    --paper-b: #d1b06d;
    --paper-c: #f4e8c3;
    --special-mark: none;
    --tape: none;
    --grain-opacity: 0.5;

    position: relative;
    min-height: 12rem;
    padding: 1.35rem 1.25rem 1.25rem;
    color: #24170d;

    background:
      var(--tape),
      var(--special-mark),
      linear-gradient(to right, rgba(60, 36, 16, 0.34), transparent 13%, transparent 87%, rgba(60, 36, 16, 0.28)),
      linear-gradient(to bottom, rgba(60, 36, 16, 0.28), transparent 15%, transparent 85%, rgba(60, 36, 16, 0.36)),
      var(--tear-line),
      radial-gradient(ellipse 30% 22% at var(--stain-x, 18%) var(--stain-y, 22%), rgba(70, 43, 20, 0.34), rgba(70, 43, 20, 0.15) 55%, transparent 78%),
      radial-gradient(ellipse 24% 26% at var(--stain-2-x, 72%) var(--stain-2-y, 78%), rgba(70, 43, 20, 0.26), rgba(70, 43, 20, 0.1) 60%, transparent 80%),
      radial-gradient(ellipse 60% 50% at 50% 45%, transparent 55%, rgba(58, 34, 16, 0.22) 100%),
      radial-gradient(circle at 28% 86%, rgba(255, 255, 255, 0.18), transparent 20%),
      linear-gradient(128deg, var(--paper-c), var(--paper-a) 42%, var(--paper-b) 78%, var(--paper-a));
    background-blend-mode:
      multiply, multiply, multiply, multiply, multiply, multiply, multiply, multiply, normal, normal;

    border: 1px solid rgba(66, 40, 18, 0.4);
    border-radius: 0;
    clip-path: var(--note-tear);

    box-shadow:
      3px 4px 0 -1px rgba(20, 11, 7, 0.1),
      6px 9px 0 -2px rgba(20, 11, 7, 0.07);

    filter:
      drop-shadow(0 4px 5px rgba(20, 11, 7, 0.22))
      drop-shadow(0 14px 18px rgba(20, 11, 7, 0.28))
      drop-shadow(0 2px 2px rgba(20, 11, 7, 0.18));

    transform: rotate(var(--note-rotation));
    isolation: isolate;
    overflow: hidden;
  }

  .character-note::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: #000;
    filter: url(#note-paper-grain);
    opacity: var(--grain-opacity);
    mix-blend-mode: multiply;
  }

  .character-note::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: #000;
    filter: url(#note-paper-fiber);
    opacity: 0.32;
    mix-blend-mode: multiply;
    mask-image:
      linear-gradient(to right, black, transparent 12%, transparent 88%, black),
      linear-gradient(to bottom, black, transparent 12%, transparent 88%, black);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .character-note h3 {
    position: relative;
    z-index: 1;
    margin: 0 0 0.55rem;
    padding: 0;
    text-align: left;
    font-family: var(--font-ui);
    font-size: 1rem;
    line-height: 1.25;
    color: rgba(72, 42, 20, 0.98);
  }

  .character-note h3::after {
    display: none;
  }

  .character-note p {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    font-weight: 650;
    color: rgba(33, 23, 15, 0.95);
  }

  /* Variante 1: vergilbtes Ledgerblatt mit Kaffee-/Bierring */
  .character-note--1 {
    --note-rotation: -2.4deg;
    --paper-a: #ead7a5;
    --paper-b: #cfaf68;
    --paper-c: #f5e9c6;
    --stain-x: 20%;
    --stain-y: 78%;
    --stain-2-x: 82%;
    --stain-2-y: 24%;
    --grain-opacity: 0.5;
    --special-mark:
      radial-gradient(circle 15% at 22% 76%, transparent 63%, rgba(64, 38, 16, 0.55) 66%, rgba(64, 38, 16, 0.3) 71%, transparent 76%),
      radial-gradient(circle 15% at 22% 76%, rgba(64, 38, 16, 0.16), transparent 70%);
    --note-tear: polygon(
      0 4%, 5% 0, 12% 3%, 21% 1%, 33% 4%, 44% 0,
      56% 3%, 67% 1%, 79% 4%, 90% 1%, 100% 3%,
      97% 17%, 100% 31%, 96% 45%, 100% 61%,
      97% 75%, 100% 89%, 96% 100%,
      84% 97%, 71% 100%, 58% 96%, 45% 100%,
      33% 97%, 20% 100%, 8% 96%, 0 99%,
      3% 84%, 0 69%, 4% 55%, 0 39%, 3% 24%
    );
    --tear-line:
      linear-gradient(116deg, transparent 0 46%, rgba(70, 43, 20, 0.28) 47% 50%, transparent 51% 100%)
      10% 22% / 34% 20% no-repeat;
  }

  /* Variante 2: rußig-graue Feldnotiz mit Brandfleck */
  .character-note--2 {
    --note-rotation: 1.8deg;
    --paper-a: #cbb083;
    --paper-b: #9a7847;
    --paper-c: #ded0a3;
    --stain-x: 78%;
    --stain-y: 18%;
    --stain-2-x: 30%;
    --stain-2-y: 72%;
    --grain-opacity: 0.62;
    --special-mark:
      radial-gradient(circle 20% at 84% 14%, rgba(20, 12, 6, 0.75), rgba(35, 21, 10, 0.5) 45%, rgba(35, 21, 10, 0.18) 68%, transparent 82%);
    --note-tear: polygon(
      2% 0, 13% 3%, 25% 1%, 38% 4%, 50% 0,
      61% 2%, 73% 0, 85% 3%, 90% 12%, 97% 4%, 100% 9%,
      95% 16%, 100% 27%, 94% 39%, 100% 52%,
      95% 64%, 100% 78%, 93% 91%, 99% 100%,
      86% 96%, 73% 100%, 62% 97%, 49% 100%,
      37% 96%, 24% 100%, 12% 97%, 0 100%,
      2% 86%, 0 73%, 3% 59%, 0 44%, 2% 29%, 0 13%
    );
    --tear-line:
      linear-gradient(45deg, transparent 0 47%, rgba(35, 21, 10, 0.3) 48% 50%, transparent 51% 100%)
      70% 18% / 24% 22% no-repeat;
  }

  /* Variante 3: sonnengebleichtes Pergament mit Wasserrand und ausgefranster Kante */
  .character-note--3 {
    --note-rotation: -1.3deg;
    --paper-a: #e8dcb8;
    --paper-b: #cdbb8a;
    --paper-c: #f6efd8;
    --stain-x: 50%;
    --stain-y: 88%;
    --stain-2-x: 12%;
    --stain-2-y: 30%;
    --grain-opacity: 0.42;
    --special-mark:
      radial-gradient(ellipse 70% 20% at 46% 92%, rgba(90, 74, 42, 0.4), rgba(90, 74, 42, 0.16) 60%, transparent 85%),
      radial-gradient(ellipse 55% 10% at 40% 80%, transparent 60%, rgba(90, 74, 42, 0.28) 78%, transparent 92%);
    --note-tear: polygon(
      0 2%, 10% 0, 21% 2%, 32% 0, 44% 3%, 55% 1%,
      68% 3%, 80% 0, 91% 2%, 100% 1%,
      98% 15%, 100% 29%, 97% 43%, 100% 57%,
      98% 71%, 100% 84%, 95% 100%,
      82% 94%, 70% 100%, 58% 93%, 45% 100%,
      33% 94%, 20% 100%, 8% 95%, 0 98%,
      2% 90%, 5% 85%, 0% 80%, 4% 74%, 0% 68%,
      3% 62%, 0% 56%, 4% 50%, 0% 44%,
      2% 38%, 0 32%, 2% 25%, 0 18%, 2% 10%
    );
    --tear-line:
      linear-gradient(90deg, transparent 0 47%, rgba(90, 74, 42, 0.24) 48% 50%, transparent 51% 100%)
      46% 82% / 36% 14% no-repeat;
  }

  /* Variante 4: dunkles Notizblatt mit Tintenklecks und Wachstropfen */
  .character-note--4 {
    --note-rotation: 2.6deg;
    --paper-a: #d3b076;
    --paper-b: #9c7439;
    --paper-c: #e6cf9c;
    --stain-x: 74%;
    --stain-y: 20%;
    --stain-2-x: 22%;
    --stain-2-y: 82%;
    --grain-opacity: 0.55;
    --special-mark:
      radial-gradient(circle 12% at 80% 16%, rgba(15, 9, 5, 0.8), rgba(15, 9, 5, 0.4) 55%, transparent 80%),
      linear-gradient(200deg, transparent 40%, rgba(15, 9, 5, 0.35) 42%, transparent 44%) 78% 22% / 30% 40% no-repeat,
      radial-gradient(circle 5% at 27% 85%, rgba(122, 20, 20, 0.65), rgba(122, 20, 20, 0.3) 60%, transparent 85%);
    --note-tear: polygon(
      0 6%, 7% 1%, 17% 4%, 29% 0, 41% 2%, 53% 0,
      66% 4%, 78% 1%, 90% 3%, 100% 0,
      96% 12%, 100% 25%, 97% 39%, 100% 54%,
      96% 68%, 100% 82%, 92% 88%, 97% 100%,
      84% 98%, 72% 100%, 60% 96%, 48% 100%,
      35% 97%, 23% 100%, 10% 94%, 0 100%,
      5% 86%, 0 72%, 4% 57%, 0 43%, 3% 29%, 0 16%
    );
    --tear-line:
      linear-gradient(62deg, transparent 0 47%, rgba(15, 9, 5, 0.32) 48% 50%, transparent 51% 100%)
      12% 76% / 30% 20% no-repeat;
  }

  @media (max-width: 850px) {
  .character-sheet__top {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .character-sheet__image {
    max-width: 300px;
    height: auto;
    margin-inline: auto;
  }

  .character-sheet__image img,
  .character-sheet__placeholder {
    height: auto;
    aspect-ratio: 3 / 4;
  }
}

  @media (max-width: 620px) {
    .character-sheet__facts {
      grid-template-columns: 1fr;
    }

    .character-sheet__notes-grid {
      grid-template-columns: 1fr;
    }

    .character-note {
      transform: none;
    }
  }
</style>
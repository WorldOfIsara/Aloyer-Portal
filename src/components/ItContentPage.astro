---
import BaseLayout from '../layouts/BaseLayout.astro';
import { itNav, itFooterDescription } from '../data/it';
import {
  portalBrandText,
  portalBrandAlt,
  portalFooterTitle,
} from '../data/portal';

interface Props {
  title: string;
  description?: string;
}

const { title, description = `${title} im IT-Bereich von Aloy.` } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  nav={itNav}
  headerBrandText={portalBrandText}
  headerBrandLogoSrc="/logos/haubentaucher-wappen-transparent.png"
  headerBrandLogoAlt={portalBrandAlt}
  headerBrandLogoFreestanding={true}
  footerTitle={portalFooterTitle}
  footerDescription={itFooterDescription}
  bodyClass="portal-welcome"
>
  <section class="surface it-page">
    <h1>{title}</h1>
    <slot />
  </section>
</BaseLayout>

<style>
  .it-page {
    text-align: center;
    max-width: 980px;
    margin-inline: auto;
  }

  .it-page p {
    max-width: 72ch;
    margin-inline: auto;
  }

  .it-page p + p {
    margin-top: 1rem;
  }
</style>

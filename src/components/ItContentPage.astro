---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingAids from './ReadingAids.astro';
import {
  itNav,
  itFooterDescription,
  itBrandText,
  itBrandAlt,
  itBrandLogoSrc,
} from '../data/it';
import {
  portalFooterTitle,
} from '../data/portal';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = `${title} im IT-Bereich von Aloy.`,
  wide = false,
} = Astro.props;

// Abschnitts-Root erkennen: passt die aktuelle URL auf einen IT-Navigationspunkt
// mit Unterseiten, zeigen wir automatisch Karten zu diesen Unterseiten.
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const section = itNav.find((item) => item.href.replace(/\/$/, '') === pathname);
const sectionChildren = section?.children ?? [];
---

<BaseLayout
  title={title}
  description={description}
  nav={itNav}
  headerBrandText={itBrandText}
  headerBrandLogoSrc={itBrandLogoSrc}
  headerBrandLogoAlt={itBrandAlt}
  headerBrandLogoFreestanding={true}
  footerTitle={portalFooterTitle}
  footerDescription={itFooterDescription}
  bodyClass="portal-welcome portal-it"
>
  <ReadingAids />

  <section class:list={['surface', 'it-page', { 'it-page--wide': wide }]}>
    <h1>{title}</h1>
    <slot />
  </section>

  {
    sectionChildren.length > 0 && (
      <nav class:list={['section-cards', { 'section-cards--wide': wide }]} aria-label={`Unterseiten von ${title}`}>
        <p class="section-cards__kicker">In diesem Abschnitt</p>
        <div class="section-cards__grid">
          {sectionChildren.map((child, index) => (
            <a class="section-card surface" href={child.href} data-reveal style={`--reveal-delay:${index * 70}ms`}>
              <span class="section-card__label">{child.label}</span>
              <svg class="section-card__arrow" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          ))}
        </div>
      </nav>
    )
  }
</BaseLayout>

<style>
  .it-page {
    text-align: left;
    max-width: 980px;
    margin-inline: auto;
  }

  .section-cards {
    display: block;
    max-width: 980px;
    margin: var(--space-5) auto 0;
  }

  .section-cards--wide {
    max-width: 1240px;
  }

  .section-cards__kicker {
    font-family: var(--font-ui);
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: rgba(230, 155, 107, 0.95);
    margin: 0 0 0.9rem;
    text-align: center;
  }

  .section-cards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 0.9rem;
  }

  .section-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.95rem 1.1rem;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-weight: 700;
    color: #16100b;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .section-card__label {
    line-height: 1.3;
  }

  .section-card__arrow {
    flex: 0 0 auto;
    color: var(--brand-1);
    opacity: 0.7;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .section-card:hover,
  .section-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(159, 72, 39, 0.55);
    box-shadow: 0 10px 22px rgba(20, 11, 7, 0.18);
  }

  .section-card:hover .section-card__arrow,
  .section-card:focus-visible .section-card__arrow {
    transform: translateX(3px);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-card,
    .section-card__arrow {
      transition: none;
    }
  }

  .it-page--wide {
    max-width: 1240px;
  }

  .it-page::after {
    content: '';
    display: block;
    clear: both;
  }

  .it-page h1 {
    text-align: center;
    margin-bottom: 1.3rem;
    position: relative;
    padding-bottom: 0.9rem;
  }

  .it-page h1::after {
    content: '';
    display: block;
    width: min(340px, 70%);
    height: 12px;
    margin: 0.75rem auto 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(92, 55, 31, 0.95) 0 2px, transparent 2px 100%),
      linear-gradient(90deg, transparent 0%, rgba(92, 55, 31, 0.85) 15%, rgba(92, 55, 31, 0.95) 50%, rgba(92, 55, 31, 0.85) 85%, transparent 100%);
    background-size:
      24px 12px,
      100% 2px;
    background-repeat: repeat-x, no-repeat;
    background-position: center, center;
  }

  .it-page :global(h2),
  .it-page :global(h3) {
    clear: both;
    text-align: center;
    position: relative;
    padding-bottom: 0.7rem;
    margin-bottom: 1rem;
  }

  .it-page :global(h2)::after,
  .it-page :global(h3)::after {
    content: '';
    display: block;
    width: min(280px, 62%);
    height: 10px;
    margin: 0.55rem auto 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(92, 55, 31, 0.88) 0 2px, transparent 2px 100%),
      linear-gradient(90deg, transparent 0%, rgba(92, 55, 31, 0.8) 16%, rgba(92, 55, 31, 0.92) 50%, rgba(92, 55, 31, 0.8) 84%, transparent 100%);
    background-size:
      22px 10px,
      100% 2px;
    background-repeat: repeat-x, no-repeat;
    background-position: center, center;
  }

  .it-page :global(p),
  .it-page :global(li) {
    max-width: none;
    margin-inline: 0;
    font-weight: 600;
    line-height: 1.72;
  }

  .it-page :global(p + p) {
    margin-top: 1rem;
  }

  @media (max-width: 700px) {
    .it-page h1 {
      margin-bottom: 1rem;
      padding-bottom: 0.65rem;
    }

    .it-page :global(h2),
    .it-page :global(h3) {
      padding-bottom: 0.55rem;
    }

    .it-page :global(p),
    .it-page :global(li) {
      line-height: 1.62;
    }

    .it-page :global(ul),
    .it-page :global(ol) {
      padding-left: 1.35rem;
    }
  }
</style>

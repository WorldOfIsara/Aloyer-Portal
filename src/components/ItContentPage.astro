---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  itNav,
  itFooterDescription,
  itBrandText,
  itBrandAlt,
  itBrandLogoSrc,
} from '../data/it';
import {
  portalFooterTitle,
} from '../data/portal';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = `${title} im IT-Bereich von Aloy.`,
  wide = false,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  nav={itNav}
  headerBrandText={itBrandText}
  headerBrandLogoSrc={itBrandLogoSrc}
  headerBrandLogoAlt={itBrandAlt}
  headerBrandLogoFreestanding={true}
  footerTitle={portalFooterTitle}
  footerDescription={itFooterDescription}
  bodyClass="portal-welcome portal-it"
>
  <section class:list={['surface', 'it-page', { 'it-page--wide': wide }]}>
    <h1>{title}</h1>
    <slot />
  </section>
</BaseLayout>

<style>
  .it-page {
    text-align: left;
    max-width: 980px;
    margin-inline: auto;
  }

  .it-page--wide {
    max-width: 1240px;
  }

  .it-page::after {
    content: '';
    display: block;
    clear: both;
  }

  .it-page h1 {
    text-align: center;
    margin-bottom: 1.3rem;
    position: relative;
    padding-bottom: 0.9rem;
  }

  .it-page h1::after {
    content: '';
    display: block;
    width: min(340px, 70%);
    height: 12px;
    margin: 0.75rem auto 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(92, 55, 31, 0.95) 0 2px, transparent 2px 100%),
      linear-gradient(90deg, transparent 0%, rgba(92, 55, 31, 0.85) 15%, rgba(92, 55, 31, 0.95) 50%, rgba(92, 55, 31, 0.85) 85%, transparent 100%);
    background-size:
      24px 12px,
      100% 2px;
    background-repeat: repeat-x, no-repeat;
    background-position: center, center;
  }

  .it-page :global(h2),
  .it-page :global(h3) {
    clear: both;
    text-align: center;
    position: relative;
    padding-bottom: 0.7rem;
    margin-bottom: 1rem;
  }

  .it-page :global(h2)::after,
  .it-page :global(h3)::after {
    content: '';
    display: block;
    width: min(280px, 62%);
    height: 10px;
    margin: 0.55rem auto 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(92, 55, 31, 0.88) 0 2px, transparent 2px 100%),
      linear-gradient(90deg, transparent 0%, rgba(92, 55, 31, 0.8) 16%, rgba(92, 55, 31, 0.92) 50%, rgba(92, 55, 31, 0.8) 84%, transparent 100%);
    background-size:
      22px 10px,
      100% 2px;
    background-repeat: repeat-x, no-repeat;
    background-position: center, center;
  }

  .it-page :global(p),
  .it-page :global(li) {
    max-width: none;
    margin-inline: 0;
    font-weight: 600;
    line-height: 1.72;
  }

  .it-page :global(p + p) {
    margin-top: 1rem;
  }

  @media (max-width: 700px) {
    .it-page h1 {
      margin-bottom: 1rem;
      padding-bottom: 0.65rem;
    }

    .it-page :global(h2),
    .it-page :global(h3) {
      padding-bottom: 0.55rem;
    }

    .it-page :global(p),
    .it-page :global(li) {
      line-height: 1.62;
    }

    .it-page :global(ul),
    .it-page :global(ol) {
      padding-left: 1.35rem;
    }
  }
</style>

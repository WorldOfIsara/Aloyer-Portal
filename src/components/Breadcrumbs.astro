---
interface Crumb {
  label: string;
  href: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="crumbs" >
  <ol>
    {
      items.map((item, index) => (
        <li>
          {index === items.length - 1 ? <span aria-current="page">{item.label}</span> : <a href={item.href}>{item.label}</a>}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .crumbs {
    margin-bottom: 1rem;
  }

  .crumbs ol {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--ink-2);
  }

  .crumbs li::after {
    content: '/';
    margin-left: 0.35rem;
    color: #90765a;
  }

  .crumbs li:last-child::after {
    content: '';
    margin: 0;
  }
</style>

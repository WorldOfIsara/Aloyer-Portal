---
import HortumSchwarzeContent from '../pages/it/glaube/drey/HortumSchwarzeContent.astro';
import MiramGraueContent from '../pages/it/glaube/drey/MiramGraueContent.astro';
import LimbaWeisseContent from '../pages/it/glaube/drey/LimbaWeisseContent.astro';
import { limbarSymbol, miramSymbol, hortumSymbol } from '../data/dreySymbols';
import '../styles/drey-wheel.css';

const withBase = (path: string) =>
  `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
---

<section class="drey" data-drey>
  <div class="drey-sanctum">
    <div class="drey-ornament drey-ornament--tl" aria-hidden="true"></div>
    <div class="drey-ornament drey-ornament--tr" aria-hidden="true"></div>
    <div class="drey-ornament drey-ornament--bl" aria-hidden="true"></div>
    <div class="drey-ornament drey-ornament--br" aria-hidden="true"></div>
    <div class="drey-side-rail drey-side-rail--left" aria-hidden="true"></div>
    <div class="drey-side-rail drey-side-rail--right" aria-hidden="true"></div>

    <div class="drey-wheel-stage">
      <div class="drey-marker" aria-hidden="true"></div>

      <div class="drey-reliquary">
        <div class="drey-wheel-window">
          <div class="drey-wheel" data-drey-wheel style="--wheel-rotation: 0deg;">
            <svg
              class="drey-svg"
              viewBox="0 0 100 100"
              aria-hidden="true"
              focusable="false"
            >
              <defs>
                <clipPath id="drey-clip-top" clipPathUnits="userSpaceOnUse">
                  <path d="M50 50 L6.7 25 A50 50 0 0 1 93.3 25 Z" />
                </clipPath>

                <clipPath id="drey-clip-right" clipPathUnits="userSpaceOnUse">
                  <path d="M50 50 L93.3 25 A50 50 0 0 1 50 100 Z" />
                </clipPath>

                <clipPath id="drey-clip-left" clipPathUnits="userSpaceOnUse">
                  <path d="M50 50 L50 100 A50 50 0 0 1 6.7 25 Z" />
                </clipPath>

                <linearGradient id="drey-divider-gold" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0" stop-color="#f2ddb0" />
                  <stop offset="0.36" stop-color="#9a642f" />
                  <stop offset="0.7" stop-color="#e0bd79" />
                  <stop offset="1" stop-color="#68401f" />
                </linearGradient>
              </defs>

              <g clip-path="url(#drey-clip-top)">
                <image
                  href={withBase('/images/it/glaube-goetter/limbar-der-weisse_wheel.webp')}
                  x="8"
                  y="-2"
                  width="84"
                  height="84"
                  preserveAspectRatio="xMidYMid meet"
                />
              </g>

              <g clip-path="url(#drey-clip-right)">
                <image
                  href={withBase('/images/it/glaube-goetter/miram-die-graue_wheel.webp')}
                  x="26"
                  y="38"
                  width="84"
                  height="84"
                  preserveAspectRatio="xMidYMid meet"
                  transform="rotate(120 70 64)"
                />
              </g>

              <g clip-path="url(#drey-clip-left)">
                <image
                  href={withBase('/images/it/glaube-goetter/hortum-der-schwarze_wheel.webp')}
                  x="-10"
                  y="38"
                  width="84"
                  height="84"
                  preserveAspectRatio="xMidYMid meet"
                  transform="rotate(-120 30 64)"
                />
              </g>

              <path class="drey-divider-shadow" d="M50 50 L6.7 25 M50 50 L93.3 25 M50 50 L50 100" />
              <path class="drey-divider-metal" d="M50 50 L6.7 25 M50 50 L93.3 25 M50 50 L50 100" />
              <path class="drey-divider-hairline" d="M50 50 L6.7 25 M50 50 L93.3 25 M50 50 L50 100" />
              <circle class="drey-divider-shadow" cx="50" cy="50" r="49.1" />
              <circle class="drey-divider-metal" cx="50" cy="50" r="49.1" />
            </svg>

            <button
              class="god-segment is-active"
              type="button"
              data-god="limba"
              aria-pressed="true"
              aria-label="Limba, den Weißen auswählen"
            >
              <span class="sr-only">Limba</span>
            </button>

            <button
              class="god-segment"
              type="button"
              data-god="miram"
              aria-pressed="false"
              aria-label="Miram, die Graue auswählen"
            >
              <span class="sr-only">Miram</span>
            </button>

            <button
              class="god-segment"
              type="button"
              data-god="hortum"
              aria-pressed="false"
              aria-label="Hortum, den Schwarzen auswählen"
            >
              <span class="sr-only">Hortum</span>
            </button>
          </div>

          <div class="drey-active-wedge" aria-hidden="true"></div>

          <div
            class="drey-center-seal"
            data-center-seal
            data-active-god="limba"
            aria-hidden="true"
          >
            <img
              class="drey-center-symbol is-active"
              data-god-symbol="limba"
              src={limbarSymbol}
              alt=""
            />
            <img
              class="drey-center-symbol"
              data-god-symbol="miram"
              src={miramSymbol}
              alt=""
            />
            <img
              class="drey-center-symbol"
              data-god-symbol="hortum"
              src={hortumSymbol}
              alt=""
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="drey-content" aria-live="polite">
    <div data-god-content="limba">
      <LimbaWeisseContent />
    </div>

    <div data-god-content="miram" hidden>
      <MiramGraueContent />
    </div>

    <div data-god-content="hortum" hidden>
      <HortumSchwarzeContent />
    </div>
  </div>
</section>

<script>
  const gods = {
    limba: { rotation: '0deg' },
    miram: { rotation: '-120deg' },
    hortum: { rotation: '120deg' }
  };

  type GodKey = keyof typeof gods;

  function initDreyWheel() {
    document.querySelectorAll<HTMLElement>('[data-drey]').forEach((root) => {
      if (root.dataset.dreyInitialized === 'true') return;

      root.dataset.dreyInitialized = 'true';

      const wheel = root.querySelector<HTMLElement>('[data-drey-wheel]');
      const buttons = root.querySelectorAll<HTMLButtonElement>('[data-god]');
      const contentBlocks = root.querySelectorAll<HTMLElement>('[data-god-content]');
      const centerSeal = root.querySelector<HTMLElement>('[data-center-seal]');
      const centerSymbols = root.querySelectorAll<HTMLElement>('[data-god-symbol]');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const key = button.dataset.god as GodKey | undefined;

          if (!key || !wheel) return;

          const god = gods[key];

          if (!god) return;

          wheel.style.setProperty('--wheel-rotation', god.rotation);

          buttons.forEach((otherButton) => {
            const isActive = otherButton === button;
            otherButton.classList.toggle('is-active', isActive);
            otherButton.setAttribute('aria-pressed', String(isActive));
          });

          contentBlocks.forEach((block) => {
            block.hidden = block.dataset.godContent !== key;
          });

          if (centerSeal) {
            centerSeal.dataset.activeGod = key;
          }

          centerSymbols.forEach((symbol) => {
            symbol.classList.toggle('is-active', symbol.dataset.godSymbol === key);
          });
        });
      });
    });
  }

  initDreyWheel();
  document.addEventListener('astro:page-load', initDreyWheel);
</script>

---
interface MapPoint {
  name: string;
  href: string;
  desc: string;
  crest?: string;
  // Position in Prozent des Kartenbildes (0–100). Bei Bedarf hier feinjustieren.
  x: number;
  y: number;
}

interface Props {
  src?: string;
  alt?: string;
  points?: MapPoint[];
}

const withBase = (path: string) => {
  if (
    path.startsWith('http://') ||
    path.startsWith('https://') ||
    path.startsWith('//') ||
    path.startsWith('#') ||
    path.startsWith('mailto:') ||
    path.startsWith('tel:') ||
    path.startsWith(import.meta.env.BASE_URL)
  ) {
    return path;
  }

  return `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
};

const defaultPoints: MapPoint[] = [
  {
    name: 'Grodaus',
    href: '/it/aloy/grodaus',
    desc: 'Hauptstadt Aloys,Sitz des Aloyer Rates,Hauptumschlag des Handels,Sitz der Akademie des wahren Glaubens zu Aloy',
    crest: '/images/it/das-land-aloy/grodaus_wappen.webp',
    x: 35.5,
    y: 47,
  },
  {
    name: 'Ohm',
    href: '/it/aloy/ohm-akademie',
    desc: 'Befestigte Grenzstadt, rote Akademie, einziger Landzugang zu Aloy.',
    crest: '/images/it/das-land-aloy/ohm_wappen.webp',
    x: 66.5,
    y: 24,
  },
  {
    name: 'Vormberg',
    href: '/it/aloy/vormberg',
    desc: 'Hauptsitz des Bergbaus. Zentrum der Kumpel und Schmiede.',
    crest: '/images/it/das-land-aloy/vormberg_wappen.webp',
    x: 16.5,
    y: 24,
  },
  {
    name: 'Umseck',
    href: '/it/aloy/umseck-waidfuath',
    desc: 'Eine kleine Stadt, die sich em Handel über den Landweg verschrieben hat.',
    crest: '/images/it/das-land-aloy/umseck_wappen.webp',
    x: 74.3,
    y: 43.7,
  },
  {
    name: 'Waidfuath',
    href: '/it/aloy/umseck-waidfuath',
    desc: 'Kleinste Stadt Aloys, mitten im Wald gelegen und etwas Weltfremd.',
    crest: '/images/it/das-land-aloy/waidfurth_wappen.webp',
    x: 23,
    y: 75,
  },
  {
    name: 'Tiafunt',
    href: '/it/aloy/tiafunt',
    desc: 'Handelszentrum, größte Hafenstadt direkt am Meer.',
    crest: '/images/it/das-land-aloy/tiafunt_wappen.webp',
    x: 74,
    y: 74.3,
  },
];

const {
  src = '/images/it/das-land-aloy/Aloy_Map.webp',
  alt = 'Karte des Landes Aloy mit Gebirgen, Flüssen und den bekannten Städten',
  points = defaultPoints,
} = Astro.props;
---

<figure class="aloy-map" data-aloy-map>
  <div class="aloy-map__frame" data-reveal="fade">
    <img
      class="aloy-map__img"
      src={withBase(src)}
      alt={alt}
      width={2048}
      height={1536}
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />

    <div class="aloy-map__layer">
      {
        points.map((point) => {
          const side = point.x > 58 ? 'left' : 'right';
          const href = withBase(point.href);

          return (
            <div
              class="aloy-map__spot"
              data-map-point
              data-side={side}
              style={`left:${point.x}%;top:${point.y}%`}
            >
              <button
                class="aloy-map__button"
                type="button"
                data-href={href}
                aria-label={`${point.name} – ${point.desc}`}
                aria-expanded="false"
              >
                <span class="aloy-map__dot" aria-hidden="true" />
              </button>

              <aside
                class="aloy-map__tip"
                aria-label={`Vorschau zu ${point.name}`}
              >
                {
                  point.crest && (
                    <img
                      class="aloy-map__crest"
                      src={withBase(point.crest)}
                      alt={`Wappen von ${point.name}`}
                      loading="lazy"
                      decoding="async"
                    />
                  )
                }

                <span class="aloy-map__tip-content">
                  <a class="aloy-map__tip-name" href={href}>
                    {point.name}
                  </a>

                  <span class="aloy-map__tip-desc">
                    {point.desc}
                  </span>
                </span>
              </aside>
            </div>
          );
        })
      }
    </div>
  </div>

  <figcaption class="aloy-map__caption">
    Klicke eine Stadt auf der Karte an, um eine Vorschau zu öffnen.
  </figcaption>

  <ul class="aloy-map__list">
    {
      points.map((point) => (
        <li>
          <a href={withBase(point.href)}>
            <strong>{point.name}</strong>
            <span>{point.desc}</span>
          </a>
        </li>
      ))
    }
  </ul>
</figure>

<style>
  .aloy-map {
    margin: 0 0 var(--space-5);
  }

  .aloy-map__frame {
    position: relative;
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(92, 55, 31, 0.45);
    box-shadow: 0 14px 34px rgba(20, 11, 7, 0.28);
    line-height: 0;
  }

  .aloy-map__img {
    display: block;
    width: 100%;
    height: auto;
  }

  .aloy-map__layer {
    position: absolute;
    inset: 0;
  }

  .aloy-map__spot {
    position: absolute;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    z-index: 1;
  }

  .aloy-map__spot:hover,
  .aloy-map__spot:focus-within,
  .aloy-map__spot.is-active {
    z-index: 6;
  }

  .aloy-map__button {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 0;
    border-radius: 999px;
    padding: 0;
    background: transparent;
    cursor: pointer;
  }

  .aloy-map__button:hover,
  .aloy-map__button:focus-visible {
    outline: none;
  }

  .aloy-map__dot {
    position: relative;
    display: block;
    width: 1.05rem;
    height: 1.05rem;
    border-radius: 999px;
    background:
      radial-gradient(
        circle at 35% 30%,
        #f3d9a6,
        #9f4827 62%,
        #7f2f1f
      );
    border: 2px solid rgba(250, 238, 210, 0.9);
    box-shadow: 0 2px 8px rgba(20, 11, 7, 0.55);
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .aloy-map__dot::after {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    width: 1.05rem;
    height: 1.05rem;
    border-radius: 999px;
    border: 2px solid rgba(159, 72, 39, 0.55);
    animation: aloy-pulse 2600ms ease-out infinite;
  }

  .aloy-map__button:hover .aloy-map__dot,
  .aloy-map__button:focus-visible .aloy-map__dot,
  .aloy-map__spot.is-active .aloy-map__dot {
    transform: scale(1.25);
    box-shadow: 0 4px 14px rgba(20, 11, 7, 0.65);
  }

  .aloy-map__tip {
    position: absolute;
    top: 50%;
    left: calc(100% + 0.55rem);
    transform: translateY(-50%) translateX(-4px);

    display: grid;
    grid-template-columns: 3.8rem minmax(10rem, 14rem);
    gap: 0.65rem;
    align-items: center;

    padding: 0.65rem 0.75rem;
    border-radius: 12px;
    background: rgba(20, 14, 10, 0.97);
    border: 1px solid rgba(212, 183, 145, 0.3);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.4);
    color: rgba(244, 233, 215, 0.96);
    line-height: 1.3;
    text-align: left;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 150ms ease,
      transform 150ms ease,
      visibility 150ms ease;
    z-index: 4;
  }

  .aloy-map__spot[data-side='left'] .aloy-map__tip {
    left: auto;
    right: calc(100% + 0.55rem);
    transform: translateY(-50%) translateX(4px);
  }

  .aloy-map__spot.is-active .aloy-map__tip {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }

  .aloy-map__crest {
    display: block;
    width: 3.8rem;
    height: 3.8rem;
    object-fit: contain;
  }

  .aloy-map__tip-content {
    display: block;
    min-width: 0;
  }

  .aloy-map__tip-name {
    display: inline-block;
    font-family: var(--font-ui);
    font-weight: 800;
    font-size: 0.95rem;
    color: rgba(244, 233, 215, 0.98);
    text-decoration: none;
  }

  .aloy-map__tip-name:hover,
  .aloy-map__tip-name:focus-visible {
    color: rgba(230, 155, 107, 0.98);
    text-decoration: underline;
    outline: none;
  }

  .aloy-map__tip-desc {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: rgba(230, 155, 107, 0.92);
    margin-top: 0.12rem;
  }

  .aloy-map__caption {
    margin: 0.7rem 0 0;
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--ink-2);
  }

  /* Auf Desktop keine Städtekacheln unter der Karte anzeigen */
  .aloy-map__list {
    display: none;
  }

  @keyframes aloy-pulse {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }

    70% {
      transform: scale(2.4);
      opacity: 0;
    }

    100% {
      transform: scale(2.4);
      opacity: 0;
    }
  }

  /* Auf Mobile und Tablet die Liste als alternative Navigation anzeigen */
  @media (max-width: 760px) {
    .aloy-map__tip {
      display: none;
    }

    .aloy-map__spot {
      width: 2rem;
      height: 2rem;
    }

    .aloy-map__button {
      width: 2rem;
      height: 2rem;
    }

    .aloy-map__caption {
      font-size: 0.82rem;
    }

    .aloy-map__list {
      list-style: none;
      margin: 1rem 0 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      align-items: stretch;
    }

    .aloy-map__list li {
      display: flex;
      min-width: 0;
    }

    .aloy-map__list a {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 0.1rem;

      width: 100%;
      height: 100%;
      min-height: 5.8rem;

      padding: 0.75rem 0.9rem;
      border-radius: var(--radius-sm);
      border: 1px solid rgba(177, 146, 104, 0.55);
      background: rgba(255, 255, 255, 0.45);
      text-decoration: none;
      color: #16100b;
      transition:
        transform 140ms ease,
        border-color 140ms ease;
    }

    .aloy-map__list a:hover,
    .aloy-map__list a:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(159, 72, 39, 0.55);
    }

    .aloy-map__list strong {
      font-family: var(--font-ui);
    }

    .aloy-map__list span {
      font-size: 0.85rem;
      color: var(--ink-2);
    }
  }

  @media (max-width: 460px) {
    .aloy-map__list {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .aloy-map__dot::after {
      animation: none;
    }

    .aloy-map__dot,
    .aloy-map__list a,
    .aloy-map__tip {
      transition: none;
    }
  }
</style>

<script>
  function initAloyMapPreviews() {
    document
      .querySelectorAll<HTMLElement>('[data-aloy-map]')
      .forEach((map) => {
        if (map.dataset.aloyMapInitialized === 'true') {
          return;
        }

        map.dataset.aloyMapInitialized = 'true';

        const points =
          map.querySelectorAll<HTMLElement>('[data-map-point]');

        const mobileQuery =
          window.matchMedia('(max-width: 760px)');

        function closeAll() {
          points.forEach((point) => {
            point.classList.remove('is-active');

            const button =
              point.querySelector<HTMLButtonElement>(
                '.aloy-map__button'
              );

            button?.setAttribute('aria-expanded', 'false');
          });
        }

        points.forEach((point) => {
          const button =
            point.querySelector<HTMLButtonElement>(
              '.aloy-map__button'
            );

          button?.addEventListener('click', (event) => {
            event.stopPropagation();

            const href = button.dataset.href;

            /*
             * Auf Mobilgeräten führt ein Klick direkt zur Stadtseite.
             * Auf Desktop öffnet der Klick zunächst das Vorschaufenster.
             */
            if (mobileQuery.matches && href) {
              window.location.href = href;
              return;
            }

            const isActive =
              point.classList.contains('is-active');

            closeAll();

            if (!isActive) {
              point.classList.add('is-active');
              button.setAttribute('aria-expanded', 'true');
            }
          });
        });

        document.addEventListener('click', (event) => {
          if (!map.contains(event.target as Node)) {
            closeAll();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeAll();
          }
        });
      });
  }

  initAloyMapPreviews();

  document.addEventListener(
    'astro:page-load',
    initAloyMapPreviews
  );
</script>
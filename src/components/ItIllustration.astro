---
interface Props {
  src: string;
  alt: string;
  caption: string;
  width: number;
  height: number;
  priority?: boolean;
  portrait?: boolean;
  align?: 'left' | 'right';
}

const {
  src,
  alt,
  caption,
  width,
  height,
  priority = false,
  portrait = false,
  align,
} = Astro.props;
---

<figure
  class:list={[
    'it-illustration',
    {
      'is-portrait': portrait,
      'is-float-left': align === 'left',
      'is-float-right': align === 'right',
    },
  ]}
>
  <div class="it-illustration-frame">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding="async"
    />
  </div>
  <figcaption>{caption}</figcaption>
</figure>

<style>
  .it-illustration {
    width: 100%;
    margin: 1.7rem auto 2.15rem;
    color: #332215;
    text-align: center;
  }

  .it-illustration:not(.is-float-left):not(.is-float-right) {
    clear: both;
  }

  .it-illustration.is-portrait {
    max-width: 530px;
  }

  .it-illustration.is-float-left,
  .it-illustration.is-float-right {
    width: min(43%, 390px);
    margin-top: 0.35rem;
    margin-bottom: 1.35rem;
  }

  .it-illustration.is-float-left {
    float: left;
    margin-right: clamp(1.2rem, 3vw, 2rem);
  }

  .it-illustration.is-float-right {
    float: right;
    margin-left: clamp(1.2rem, 3vw, 2rem);
  }

  .it-illustration-frame {
    position: relative;
    padding: clamp(0.35rem, 0.8vw, 0.55rem);
    border: 1px solid rgba(74, 45, 27, 0.72);
    background: rgba(224, 202, 157, 0.42);
    box-shadow:
      0 12px 28px rgba(49, 28, 17, 0.18),
      inset 0 0 0 3px rgba(255, 248, 224, 0.34),
      inset 0 0 0 4px rgba(96, 59, 35, 0.28);
  }

  .it-illustration-frame::before,
  .it-illustration-frame::after {
    content: '';
    position: absolute;
    z-index: 1;
    width: 34px;
    height: 34px;
    pointer-events: none;
  }

  .it-illustration-frame::before {
    top: 0.2rem;
    left: 0.2rem;
    border-top: 2px solid rgba(82, 48, 28, 0.78);
    border-left: 2px solid rgba(82, 48, 28, 0.78);
  }

  .it-illustration-frame::after {
    right: 0.2rem;
    bottom: 0.2rem;
    border-right: 2px solid rgba(82, 48, 28, 0.78);
    border-bottom: 2px solid rgba(82, 48, 28, 0.78);
  }

  img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid rgba(45, 29, 19, 0.5);
    filter: sepia(0.14) contrast(0.96) brightness(1.02);
  }

  figcaption {
    max-width: 48rem;
    margin: 0.7rem auto 0;
    font-size: clamp(0.95rem, 1.6vw, 1.08rem);
    font-style: italic;
    font-weight: 600;
    line-height: 1.45;
  }

  figcaption::before,
  figcaption::after {
    content: '·';
    padding-inline: 0.5rem;
    color: rgba(88, 50, 28, 0.8);
  }

  @media (max-width: 720px) {
    .it-illustration.is-float-left,
    .it-illustration.is-float-right {
      float: none;
      width: 100%;
      max-width: 530px;
      margin: 1.7rem auto 2.15rem;
    }
  }
</style>

---
import { getFotostreckeFiles } from '../lib/fotostrecke';

interface Props {
  autoplayMs?: number;
}

const { autoplayMs = 4000 } = Astro.props;

function toPhotoAlt(fileName: string): string {
  const readableFileName = fileName
    .replace(/\.[^.]+$/, '')
    .replace(/[_-]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  if (readableFileName.length === 0) {
    return 'Fotostrecke Bild';
  }

  return `Fotostrecke: ${readableFileName}`;
}

const fotostreckeImages = getFotostreckeFiles().map((file, index) => ({
  src: `/fotostrecke/${index}`,
  alt: toPhotoAlt(file.fileName),
}));

const hasFotostreckeImages = fotostreckeImages.length > 0;
---

<section class="surface slideshow-block" aria-label="Fotostrecke">
  {
    hasFotostreckeImages ? (
      <>
        <div class="slideshow" data-slideshow data-autoplay-ms={autoplayMs}>
          <button class="slide-nav left" type="button" aria-label="Vorheriges Bild" data-action="prev">
            &#8249;
          </button>
          <figure class="slideshow-figure">
            <img
              data-photo
              src={fotostreckeImages[0].src}
              alt={fotostreckeImages[0].alt}
              loading="lazy"
              decoding="async"
            />
          </figure>
          <button class="slide-nav right" type="button" aria-label="N&auml;chstes Bild" data-action="next">
            &#8250;
          </button>
        </div>
        <script type="application/json" id="fotostrecke-data" set:html={JSON.stringify(fotostreckeImages)}></script>
        <script>
          const slideshowRoot = document.querySelector('[data-slideshow]');
          const slideshowData = document.getElementById('fotostrecke-data');

          if (slideshowRoot && slideshowData?.textContent) {
            const imageElement = slideshowRoot.querySelector('[data-photo]');
            const previousButton = slideshowRoot.querySelector('[data-action="prev"]');
            const nextButton = slideshowRoot.querySelector('[data-action="next"]');

            const parsedImages = JSON.parse(slideshowData.textContent);
            if (
              Array.isArray(parsedImages) &&
              parsedImages.length > 0 &&
              imageElement instanceof HTMLImageElement
            ) {
              const rawAutoplayMs = Number.parseInt(slideshowRoot.getAttribute('data-autoplay-ms') ?? '', 10);
              const autoplayMs = Number.isFinite(rawAutoplayMs) && rawAutoplayMs > 0 ? rawAutoplayMs : 4000;
              const images = [...parsedImages];

              for (let currentIndex = images.length - 1; currentIndex > 0; currentIndex -= 1) {
                const randomIndex = Math.floor(Math.random() * (currentIndex + 1));
                const temp = images[currentIndex];
                images[currentIndex] = images[randomIndex];
                images[randomIndex] = temp;
              }

              let activeIndex = 0;
              let intervalId: number | undefined;

              const renderActiveImage = () => {
                const currentImage = images[activeIndex];
                imageElement.src = currentImage.src;
                imageElement.alt = currentImage.alt;
              };

              const showNext = () => {
                activeIndex = (activeIndex + 1) % images.length;
                renderActiveImage();
              };

              const showPrevious = () => {
                activeIndex = (activeIndex - 1 + images.length) % images.length;
                renderActiveImage();
              };

              const restartAutoplay = () => {
                if (intervalId !== undefined) {
                  window.clearInterval(intervalId);
                }
                intervalId = window.setInterval(showNext, autoplayMs);
              };

              previousButton?.addEventListener('click', () => {
                showPrevious();
                restartAutoplay();
              });

              nextButton?.addEventListener('click', () => {
                showNext();
                restartAutoplay();
              });

              renderActiveImage();
              restartAutoplay();
            }
          }
        </script>
      </>
    ) : (
      <p>Die Fotostrecke wird aktuell vorbereitet.</p>
    )
  }
</section>

<style>
  .slideshow-block {
    text-align: center;
    max-width: 980px;
    margin-inline: auto;
    padding-bottom: 2rem;
  }

  .slideshow {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
  }

  .slideshow-figure {
    margin: 0;
  }

  .slideshow-figure img {
    display: block;
    width: 100%;
    max-width: 860px;
    margin-inline: auto;
    max-height: 520px;
    object-fit: cover;
    border-radius: 0.65rem;
    box-shadow: 0 12px 24px rgb(0 0 0 / 0.35);
    background: rgb(14 14 14 / 0.55);
  }

  .slide-nav {
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid rgb(230 205 160 / 0.45);
    border-radius: 999px;
    background: rgb(20 12 7 / 0.84);
    color: rgb(242 230 210 / 0.94);
    cursor: pointer;
    font-size: 1.45rem;
    line-height: 1;
    transition: background-color 160ms ease, transform 160ms ease;
  }

  .slide-nav:hover,
  .slide-nav:focus-visible {
    background: rgb(42 27 18 / 0.94);
    transform: translateY(-1px);
    outline: none;
  }

  @media (max-width: 820px) {
    .slideshow {
      grid-template-columns: 1fr auto auto;
      gap: 0.6rem;
    }

    .slideshow-figure {
      grid-column: 1 / -1;
      order: 0;
    }

    .slide-nav.left {
      order: 1;
      justify-self: end;
    }

    .slide-nav.right {
      order: 2;
      justify-self: start;
    }
  }

  @media (max-width: 480px) {
    .slideshow-block {
      padding-bottom: 1rem;
    }

    .slideshow {
      margin-top: 0.5rem;
      gap: 0.5rem;
    }

    .slideshow-figure img {
      max-height: min(58vh, 420px);
      border-radius: 0.5rem;
    }

    .slide-nav {
      width: 44px;
      height: 44px;
    }
  }
</style>

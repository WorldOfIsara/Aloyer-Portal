---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Aloy Portal',
  description = 'Portal + Wiki f\u00fcr Einstieg, Lore, Chronik und Downloads.',
} = Astro.props;
const pathname = Astro.url.pathname;
const isOt = !pathname.startsWith('/it');
const modeSwitchLabel = 'Bereich w\u00e4hlen';
---

<footer class="site-footer">
  <div class="wrap">
    <div>
      <p class="title">{title}</p>
      <p class="muted">{description}</p>
    </div>

    <div class="nav-col">
      <div class="links">
        <a href="/">Landingpage</a>
        <a href="/ot/willkommen">Start</a>
        <a href="/it/vorrede">IT-Bereich</a>
        <a href="/ot/willkommen">OT-Bereich</a>
        <a href="/kontakt">Kontakt</a>
      </div>

      <div class="mode-switch" role="group" aria-label={modeSwitchLabel}>
        <span class="mode-label">IT</span>
        <label class="switch" for="footerModeSwitch">
          <input id="footerModeSwitch" type="checkbox" checked={isOt} />
          <span class="slider" aria-hidden="true"></span>
        </label>
        <span class="mode-label">OT</span>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  const footerModeSwitch = document.getElementById('footerModeSwitch');
  if (footerModeSwitch) {
    footerModeSwitch.addEventListener('change', () => {
      window.location.href = footerModeSwitch.checked ? '/ot/willkommen' : '/it/vorrede';
    });
  }
</script>

<style>
  .site-footer {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    transform: none;
    width: 100%;
    z-index: 40;
    border: 0;
    border-radius: 0;
    background: rgba(10, 7, 5, 0.96);
    backdrop-filter: none;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.35);
  }

  .wrap {
    width: 100%;
    margin: 0;
    padding: 1rem 1.2rem 1.15rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.1rem;
  }

  .muted {
    margin: 0.35rem 0 0;
  }

  .nav-col {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.55rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: flex-start;
    gap: 0.7rem;
    font-family: var(--font-ui);
  }

  .mode-switch {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    opacity: 0.75;
  }

  .mode-label {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-2);
  }

  .switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 26px;
  }

  .switch input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    opacity: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background: rgba(255, 255, 255, 0.34);
    border: 1px solid rgba(177, 146, 104, 0.62);
    border-radius: 999px;
    transition: background-color 160ms ease;
  }

  .slider::before {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    left: 3px;
    top: 3px;
    border-radius: 999px;
    background: linear-gradient(120deg, var(--brand-0), var(--brand-1));
    transition: transform 160ms ease;
    box-shadow: 0 1px 5px rgba(52, 38, 26, 0.24);
  }

  .switch input:checked + .slider {
    background: rgba(47, 94, 68, 0.24);
  }

  .switch input:checked + .slider::before {
    transform: translateX(24px);
  }

  .switch input:focus-visible + .slider {
    outline: 3px solid rgba(255, 255, 255, 0.7);
    outline-offset: 3px;
  }

  @media (max-width: 760px) {
    .site-footer {
      position: static;
      margin-top: auto;
      box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.2);
    }

    .wrap {
      padding:
        1.1rem max(0.9rem, env(safe-area-inset-right))
        calc(1rem + env(safe-area-inset-bottom))
        max(0.9rem, env(safe-area-inset-left));
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
    }

    .nav-col {
      width: 100%;
      align-items: flex-start;
    }

    .links {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
      gap: 0.2rem 0.75rem;
    }

    .links a {
      display: flex;
      align-items: center;
      min-height: 44px;
      padding-block: 0.35rem;
    }

    .mode-switch {
      min-height: 44px;
      opacity: 0.92;
    }

    :global(body.portal-welcome main) {
      padding-bottom: var(--space-5);
    }
  }

  @media (max-width: 380px) {
    .links {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (min-width: 761px) {
    :global(body.portal-welcome main) {
      padding-bottom: 12rem;
    }
  }
</style>

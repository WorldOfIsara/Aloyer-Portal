---
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { eyebrow, title, intro, primaryCta, secondaryCta } = Astro.props;
---

<section class="hero surface">
  <p class="kicker">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="intro">{intro}</p>
  <div class="cta-row">
    {primaryCta && <a href={primaryCta.href} class="btn">{primaryCta.label}</a>}
    {secondaryCta && (
      <a href={secondaryCta.href} class="btn btn-secondary">
        {secondaryCta.label}
      </a>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 999px;
    z-index: -1;
  }

  .hero::before {
    width: 240px;
    height: 240px;
    right: -90px;
    top: -70px;
    background: rgba(159, 72, 39, 0.16);
  }

  .hero::after {
    width: 270px;
    height: 270px;
    left: -120px;
    bottom: -140px;
    background: rgba(192, 109, 61, 0.2);
  }

  .intro {
    max-width: 70ch;
    color: var(--ink-2);
  }

  .cta-row {
    margin-top: 1.2rem;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
</style>

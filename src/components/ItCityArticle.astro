---
import ItIllustration from './ItIllustration.astro';
import TextDivider from './TextDivider.astro';

interface CityFact {
  label: string;
  value: string;
}

interface Props {
  name: string;
  subtitle?: string;

  imageSrc: string;
  imageAlt: string;
  imageCaption?: string;
  imageWidth?: number;
  imageHeight?: number;
  imagePriority?: boolean;

  crestSrc: string;
  crestAlt?: string;

  summary?: string;
  facts?: CityFact[];
}

const withBase = (path: string) => {
  if (
    path.startsWith('http://') ||
    path.startsWith('https://') ||
    path.startsWith('//') ||
    path.startsWith('#') ||
    path.startsWith('mailto:') ||
    path.startsWith('tel:') ||
    path.startsWith(import.meta.env.BASE_URL)
  ) {
    return path;
  }

  return `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
};

const {
  name,
  subtitle,

  imageSrc,
  imageAlt,
  imageCaption = '',
  imageWidth = 1500,
  imageHeight = 845,
  imagePriority = false,

  crestSrc,
  crestAlt = `Wappen von ${name}`,

  summary,
  facts = [],
} = Astro.props;
---

<article class="city-article">
  

  <section class="city-identity" aria-label={`Übersicht zu ${name}`}>
    <div class="city-identity__crest-wrap">
      <img
        class="city-identity__crest"
        src={withBase(crestSrc)}
        alt={crestAlt}
        loading="eager"
        decoding="async"
      />
    </div>

    <div class="city-identity__text">
      <p class="city-identity__kicker">Stadt Aloys</p>

      <h2>{name}</h2>

      {subtitle && <p class="city-identity__subtitle">{subtitle}</p>}

      {summary && <p class="city-identity__summary">{summary}</p>}
    </div>
  </section>

  {
    facts.length > 0 && (
      <dl class="city-facts" aria-label={`Kurzdaten zu ${name}`}>
        {facts.map((fact) => (
          <div class="city-facts__item">
            <dt>{fact.label}</dt>
            <dd>{fact.value}</dd>
          </div>
        ))}
      </dl>
    )
  }

  <ItIllustration
    src={withBase(imageSrc)}
    alt={imageAlt}
    caption={imageCaption}
    width={imageWidth}
    height={imageHeight}
    priority={imagePriority}
  />
  <TextDivider />
  <div class="city-content">
    <slot />
  </div>
</article>

<style>
  .city-article {
    display: block;
  }

  .city-identity {
    display: grid;
    grid-template-columns: clamp(7rem, 18vw, 11rem) 1fr;
    gap: 1.5rem;
    align-items: center;
    margin: 2rem 0 1.5rem;
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(92, 55, 31, 0.35);
    background:
      radial-gradient(circle at 12% 20%, rgba(230, 155, 107, 0.18), transparent 34%),
      rgba(255, 255, 255, 0.38);
    box-shadow: 0 10px 24px rgba(20, 11, 7, 0.12);
  }

  .city-identity__crest-wrap {
  display: grid;
  place-items: center;
  aspect-ratio: 1;
  padding: 0.75rem;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.28);
  border: 1px solid rgba(92, 55, 31, 0.28);
  box-shadow: 0 10px 20px rgba(20, 11, 7, 0.1);
}

.city-identity__crest {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 0;
}

  .city-identity__text {
    min-width: 0;
  }

  .city-identity__kicker {
    margin: 0 0 0.25rem;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.95);
  }

  .city-identity h2 {
    margin: 0;
    text-align: left;
    padding-bottom: 0;
  }

  .city-identity h2::after {
    display: none;
  }

  .city-identity__subtitle {
    margin: 0.35rem 0 0;
    font-family: var(--font-ui);
    font-weight: 700;
    color: rgba(92, 55, 31, 0.95);
  }

  .city-identity__summary {
    margin: 0.75rem 0 0;
    line-height: 1.6;
  }

  .city-facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin: 0 0 1.75rem;
  }

  .city-facts__item {
    padding: 0.85rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(177, 146, 104, 0.55);
    background: rgba(255, 255, 255, 0.45);
  }

  .city-facts dt {
    margin: 0 0 0.2rem;
    font-family: var(--font-ui);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(159, 72, 39, 0.92);
  }

  .city-facts dd {
    margin: 0;
    font-weight: 700;
    line-height: 1.35;
  }

  .city-content {
    margin-top: 1.25rem;
  }

  @media (max-width: 760px) {
    .city-identity {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .city-identity__crest-wrap {
      width: min(11rem, 58vw);
      margin-inline: auto;
    }

    .city-identity h2 {
      text-align: center;
    }

    .city-facts {
      grid-template-columns: 1fr;
    }
  }
</style>
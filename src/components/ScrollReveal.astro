---
// Globaler Scroll-Reveal-Beobachter. Einmal im BaseLayout eingebunden.
// Jedes Element mit [data-reveal] blendet beim Hereinscrollen sanft ein.
// Varianten: data-reveal="up" (Standard) | "fade" | "left" | "right".
// Verzögerung/Stagger über inline-style --reveal-delay (z. B. style="--reveal-delay:120ms").
---

<script is:inline>
  (() => {
    const root = document.documentElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    // Ohne Motion oder ohne IntersectionObserver: Inhalte bleiben einfach sichtbar.
    if (reduce.matches || typeof IntersectionObserver !== 'function') return;

    // Verstecken erst aktivieren, wenn JS läuft -> kein Flash, kein Verstecken ohne JS.
    root.classList.add('reveal-active');

    const reveal = (el) => el.classList.add('is-visible');

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            reveal(entry.target);
            obs.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
    );

    const observeAll = () => {
      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((el) => observer.observe(el));
    };

    observeAll();

    // Sicherheitsnetz: falls etwas nicht beobachtet wurde, nach kurzer Zeit zeigen.
    window.setTimeout(() => {
      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight) reveal(el);
      });
    }, 1200);
  })();
</script>

<style is:global>
  html.reveal-active [data-reveal] {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 620ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  html.reveal-active [data-reveal='fade'] {
    transform: none;
  }

  html.reveal-active [data-reveal='left'] {
    transform: translateX(-26px);
  }

  html.reveal-active [data-reveal='right'] {
    transform: translateX(26px);
  }

  html.reveal-active [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }
</style>

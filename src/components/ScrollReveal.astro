---
// Globaler Scroll-Reveal-Beobachter. Einmal im BaseLayout eingebunden.
// Jedes Element mit [data-reveal] blendet beim Hereinscrollen sanft ein.
// Varianten: data-reveal="up" (Standard) | "fade" | "left" | "right".
// Verzögerung/Stagger über inline-style --reveal-delay (z. B. style="--reveal-delay:120ms").
// Standard: einmaliges Einblenden, bleibt danach sichtbar (unobserve nach Reveal).
// Mit zusätzlichem [data-reveal-repeat]: blendet auch wieder aus, wenn das
// Element den Viewport wieder verlässt (in beide Scrollrichtungen).
---

<script is:inline>
  (() => {
    const root = document.documentElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    // Ohne Motion oder ohne IntersectionObserver: Inhalte bleiben einfach sichtbar.
    if (reduce.matches || typeof IntersectionObserver !== 'function') return;

    // Verstecken erst aktivieren, wenn JS läuft -> kein Flash, kein Verstecken ohne JS.
    root.classList.add('reveal-active');

    const reveal = (el) => el.classList.add('is-visible');
    const hide = (el) => el.classList.remove('is-visible');

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          const repeat = entry.target.hasAttribute('data-reveal-repeat');
          if (entry.isIntersecting) {
            reveal(entry.target);
            if (!repeat) obs.unobserve(entry.target);
          } else if (repeat) {
            hide(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
    );

    const observeAll = () => {
      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((el) => observer.observe(el));
    };

    observeAll();

    // Sicherheitsnetz: falls etwas nicht beobachtet wurde, nach kurzer Zeit zeigen.
    window.setTimeout(() => {
      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight) reveal(el);
      });
    }, 1200);
  })();
</script>

<style is:global>
  html.reveal-active [data-reveal] {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 620ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  html.reveal-active [data-reveal='fade'] {
    transform: none;
  }

  html.reveal-active [data-reveal='left'] {
    transform: translateX(-26px);
  }

  html.reveal-active [data-reveal='right'] {
    transform: translateX(26px);
  }

  html.reveal-active [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  /*
    Die Onepager-Panels selbst (.surface.onepager-block, seit kurzem auch
    data-reveal statt nur ihrer inneren Textblöcke) wirkten mit den
    Standard-620ms zu abrupt/heftig - für die großen Panels langsamer und
    sanfter, unabhängig von der Geschwindigkeit der inneren Textblöcke.
  */
  html.reveal-active .surface.onepager-block[data-reveal] {
    transition-duration: 1100ms;
  }
</style>
